@page "/cloudrecords"
@using System.Net.Http.Json
@using CloudAccountsShared.Models
@using CloudAccountsShared.Models.DTOs
@using CloudAccountsUI.Dialogs.AuditDialogs
@using CloudAccountsUI.Services
@using CloudAccountsUI.Services.Contracts
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@inject ICloudRecordsService CloudRecordsService
@inject ICloudHistoryService CloudHistoryService
@inject IDialogService DialogService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject IBusinessFunctionService BusinessFunctionService

<div class="full-page-container">
    <div class="main-wrapper @(drawerOpen && !drawerFullscreen ? "drawer-open" : "") @(drawerFullscreen ? "fullscreen-active" : "")">
        <div class="pushed-content">

            <!-- Data Grid -->
            <div class="grid-container">
                @if (isLoading)
                {
                    <div style="display: flex; justify-content: center; align-items: center; height: 400px;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                    </div>
                }
                else if (cloudAccounts.Count == 0)
                {
                    <div style="display: flex; justify-content: center; align-items: center; height: 400px; flex-direction: column;">
                        <MudIcon Icon="@Icons.Material.Filled.CloudOff" Size="Size.Large" Style="color: #CBD5E1; margin-bottom: 16px;" />
                        <MudText Typo="Typo.h6" Style="color: #5A6A85;">No cloud accounts found</MudText>
                        <MudText Typo="Typo.body2" Style="color: #94A3B8; margin-top: 8px;">No data available for the selected provider</MudText>
                    </div>
                }
                else
                {
                    <MudDataGrid T="CloudAccountDetailsDTO"
                                 @ref="_dataGrid"
                                 Items="@FilteredAccounts"
                                 Dense="true"
                                 Hover="true"
                                 Bordered="true"
                                 Striped="true"
                                 Filterable="true"
                                 FilterMode="DataGridFilterMode.ColumnFilterRow"
                                 FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive"
                                 ShowColumnOptions="true"
                                 FixedHeader="true"
                                 @bind-PageSize="PageSize"
                                 RowsPerPageOptions="@PageSizeOptions"
                                 Height="100%"
                                 Width="100%"
                                 Loading="@isLoading"
                                 ColumnResizeMode="ResizeMode.Column"
                                 DragDropColumnReordering="true"
                                 ColumnsPanelReordering="true"
                                 ShowMenuIcon="true"
                                 RowContextMenuClick="OpenContextMenu">

                        <ToolBarContent>
                            <div class="toolbar-container">
                                <div class="title-tabs-section">
                                    <div class="title-section">
                                        <MudIcon Icon="@Icons.Material.Filled.Cloud" Class="mr-2" Style="color: #00A3FF;" />
                                        <div>
                                            <div class="cs-title">Cloud Accounts Management</div>
                                            <div class="cs-subtitle">Manage and monitor all your cloud accounts across providers</div>
                                        </div>
                                    </div>

                                    <div class="tabs-section">
                                        <MudTabs Rounded="true"
                                                 Elevation="0"
                                                 Class="crowdstrike-tabs"
                                                 ActivePanelIndexChanged="OnTabChanged">

                                            <MudTabPanel Text="@AllTabText" Class="crowdstrike-tab" />
                                            <MudTabPanel Text="@AwsTabText" Class="crowdstrike-tab" />
                                            <MudTabPanel Text="@AzureTabText" Class="crowdstrike-tab" />
                                            <MudTabPanel Text="@GcpTabText" Class="crowdstrike-tab" />
                                        </MudTabs>
                                    </div>
                                </div>

                                <div class="export-section">
                                    <MudTooltip Text="Export To CSV" Arrow="true" Placement="Placement.Top">
                                        <MudIconButton Icon="@Icons.Material.Filled.Download"
                                                       Style="color: #5A6A85;"
                                                       Size="Size.Small"
                                                       OnClick="ExportCsv" />
                                    </MudTooltip>
                                </div>
                            </div>
                        </ToolBarContent>

                        <Columns>
                            
                            @foreach (var columnConfig in GetVisibleColumns())
                            {
                               
                                if (columnConfig.GenericKey == "CloudAccountId")
                                {
                                    <TemplateColumn Title="@columnConfig.Title"
                                                    Resizable="true"
                                                    Hideable="true"
                                                    StickyLeft="@columnConfig.IsStickyLeft">

                                        <FilterTemplate Context="context">
                                            <MudTextField T="string"
                                                Value="@(context.FilterDefinition?.Value?.ToString() ?? string.Empty)"
                                                ValueChanged="@(v =>
                                                {
                                                    if (context.FilterDefinition is not null)
                                                        context.FilterDefinition.Value = v;
                                                })"
                                              Placeholder="Filter..."
                                              Margin="Margin.Dense"
                                              Immediate="true"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@Icons.Material.Filled.Search" />
                            </FilterTemplate>

                                    <CellTemplate Context="cell">
                                        <div class="cloud-account-id-cell">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                            Size="Size.Small"
                                                            Class="edit-button-inline"
                                                            OnClick="() => OpenDrawer(cell.Item)"
                                                            Style="color: #00A3FF; margin-right: 8px;" />
                                        <div class="cell-content">
                                                    @{
                                                        var value = GetPropertyValue(cell.Item, columnConfig.PropertyName);
                                                    }

                                                    @if (value != null)
                                                    {
                                                        <MudTooltip Text="@value.ToString()" Placement="Placement.Top">
                                                            <span class="truncate-text">@value</span>
                                                        </MudTooltip>
                                                    }
                                                    else
                                                    {
                                                        <span>-</span>
                                                    }
                                                </div>
                                            </div>
                                        </CellTemplate>
                                    </TemplateColumn>
                                }
                                else
                                {
                                    <PropertyColumn Property="@(GetPropertyExpression(columnConfig.PropertyName))"
                                                    Title="@columnConfig.Title"
                                                    Resizable="true"
                                                    StickyLeft="@columnConfig.IsStickyLeft"
                                                    Hideable="true"/>
                                }
                            }
                        </Columns>

                        <NoRecordsContent>
                            <MudText Class="pa-4" Style="color: #5A6A85;">No matching records found</MudText>
                        </NoRecordsContent>

                        <PagerContent>
                            <MudDataGridPager T="CloudAccountDetailsDTO" PageSizeOptions="@PageSizeOptions" />
                        </PagerContent>
                    </MudDataGrid>
                }
            </div>
        </div>
    </div>

    <div class="drawer-container @(drawerOpen ? "open" : "") @(drawerFullscreen ? "fullscreen" : "")">
        @if (drawerOpen && editingAccount is not null)
        {
            <div class="drawer-content">
                <div class="drawer-header">
                    <div class="drawer-title">Edit Cloud Account</div>
                    <div class="drawer-buttons">
                        <MudIconButton Icon="@(drawerFullscreen? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                                       Size="Size.Medium"
                                       Color="Color.Default"
                                       OnClick="ToggleFullscreen" />
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Size="Size.Medium"
                                       Color="Color.Default"
                                       OnClick="CloseDrawer" />
                    </div>
                </div>

                <div style="flex: 1; overflow-y: auto; padding-right: 8px;">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.subtitle2" Style="color: #1A1D2E; font-size: 13px; font-weight: 600;">Cloud Details</MudText>

                        <MudTextField T="string"
                                      Label="Provider"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.Provider"
                                      Disabled="true"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Cloud Account ID"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.CloudAccountId"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Cloud Name"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.CloudName"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Cloud Org ID"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.CloudOrgId"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Cloud Root Account ID"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.CloudRootAccountID"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Registration Type"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.RegistrationType"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Deployment Method"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.DeploymentMethod"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Registered At CRWD"
                                      Variant="Variant.Outlined"
                                      Value="@(editingAccount.RegisteredAtCRWD?.ToString("yyyy-MM-dd HH:mm") ?? "-")"
                                      Disabled="true"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Last Updated At CRWD"
                                      Variant="Variant.Outlined"
                                      Value="@(editingAccount.LastUpdatedAtCRWD?.ToString("yyyy-MM-dd HH:mm") ?? "-")"
                                      Disabled="true"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="IOM Status"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.IOMStatus"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="RTVD Status"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.RealTimeVisibilityAndDetectionStatus"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="1-Click Sensor Status"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.OneClickSensorStatus"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Identity Protection Status"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.IdentityProtectionStatus"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="DSPM Status"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.DSPMStatus"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Vulnerability Scanning Status"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.VulnerabilityScanningStatus"
                                      Dense="true" />

                        <MudDivider Class="my-3" />

                        <MudText Typo="Typo.subtitle2" Style="color: #1A1D2E; font-size: 13px; font-weight: 600;">Business Function</MudText>

                        <MudAutocomplete T="BusinessFunctionMaster"
                                         Label="Business Function Name"
                                         Variant="Variant.Outlined"
                                         Dense="true"
                                         Value="selectedBusinessFunction"
                                         ValueChanged="OnBusinessFunctionChanged"
                                         SearchFunc="SearchBusinessFunctions"
                                         ToStringFunc="@(x => x?.BusinessFunctionName ?? string.Empty)"
                                         Clearable="false" />

                        <MudTextField T="string"
                                      Label="Owner"
                                      Variant="Variant.Outlined"
                                      Value="selectedBusinessFunction?.BusinessFunctionOwner"
                                      Dense="true"
                                      Disabled="true" />

                        <MudTextField T="string"
                                      Label="LT Member"
                                      Variant="Variant.Outlined"
                                      Value="selectedBusinessFunction?.BusinessFunctionLtMember"
                                      Dense="true"
                                      Disabled="true" />

                        <MudTextField T="string"
                                      Label="SPOC"
                                      Variant="Variant.Outlined"
                                      Value="selectedBusinessFunction?.BusinessFunctionSpoc"
                                      Dense="true"
                                      Disabled="true" />

                        <MudTextField T="string"
                                      Label="Business Tag Value"
                                      Variant="Variant.Outlined"
                                      Value="selectedBusinessFunction?.BusinessTagValue"
                                      Dense="true"
                                      Disabled="true" />

                        <MudTextField T="string"
                                      Label="Business Function Remarks"
                                      Variant="Variant.Outlined"
                                      Value="selectedBusinessFunction?.Remarks"
                                      Dense="true"
                                      Disabled="true" />

                        <MudDivider Class="my-3" />

                        <MudText Typo="Typo.subtitle2" Style="color: #1A1D2E; font-size: 13px; font-weight: 600;">Manual Details</MudText>

                        <MudSelect T="string"
                                   Label="Account Type"
                                   Variant="Variant.Outlined"
                                   @bind-Value="editingAccount.AccountType"
                                   Dense="true">

                            <MudSelectItem Value='"Hybrid"'>Hybrid</MudSelectItem>
                            <MudSelectItem Value='"Managed"'>Managed</MudSelectItem>
                            <MudSelectItem Value='"Self - Managed"'>Self-Managed</MudSelectItem>
                            <MudSelectItem Value='"Sandbox"'>Sandbox</MudSelectItem>
                            <MudSelectItem Value='"SingleAccount"'>SingleAccount</MudSelectItem>
                        </MudSelect>

                        <MudSelect T="string"
                                   Label="Overall Status"
                                   Variant="Variant.Outlined"
                                   @bind-Value="editingAccount.OverallStatus"
                                   Dense="true">

                            <MudSelectItem Value='"Active"'>Active</MudSelectItem>
                            <MudSelectItem Value='"Deleted"'>Deleted</MudSelectItem>
                            <MudSelectItem Value='"Disabled"'>Disabled</MudSelectItem>
                        </MudSelect>

                        <MudTextField T="string"
                                      Label="Manual Remarks"
                                      Variant="Variant.Outlined"
                                      Lines="3"
                                      @bind-Value="editingAccount.ManualRemarks" />

                        @* <MudTextField T="string"
                                      Label="Attachment Path"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.AttachmentPath"
                                      Dense="true" /> *@
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <InputFile OnChange="UploadAttachment" />

                                @if (!string.IsNullOrWhiteSpace(editingAccount.AttachmentPath))
                                {
                                    <MudText Typo="Typo.body2">
                                        @Path.GetFileName(editingAccount.AttachmentPath)
                                    </MudText>

                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="RemoveAttachment" />
                                }
                            </MudStack>

                    </MudStack>
                </div>

                <div class="drawer-footer">
                    <MudButton Variant="Variant.Text"
                               OnClick="CloseDrawer"
                               Style="color: #5A6A85;">
                        Cancel
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Style="background: #00A3FF; color: white; font-weight: 600;"
                               OnClick="SaveEdit"
                               Disabled="@isSaving">
                        @if (isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                            <span class="ml-2">Saving...</span>
                        }
                        else
                        {
                            <span>Save</span>
                        }
                    </MudButton>
                </div>
            </div>
        }
    </div>
</div>

<MudMenu PositionAtCursor="true" @ref="_contextMenu" id="_contextMenu">
    <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => EditFromContext())">
        Edit @_contextRow?.CloudName
    </MudMenuItem>
    <MudMenuItem Icon="@Icons.Material.Filled.Info" OnClick="@ShowAudits">
        View Audits for @_contextRow?.CloudAccountId
    </MudMenuItem>
</MudMenu>

<style>
    ::deep .mud-layout {
        padding: 0 !important;
        margin: 0 !important;
    }

    ::deep .mud-main-content {
        padding: 0 !important;
        margin: 0 !important;
    }

    .full-page-container {
        width: 100%;
        height: 100vh;
        padding: 0;
        margin: 0;
        overflow: hidden;
        background: white;
        display: flex;
        flex-direction: column;
    }

    .main-wrapper {
        flex: 1;
        display: flex;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .pushed-content {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .grid-container {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
