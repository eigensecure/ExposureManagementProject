    .tabs-section {
        flex: 1;
    }

    .crowdstrike-tabs {
        background: transparent !important;
    }

        .crowdstrike-tabs .mud-tabs-toolbar {
            background: transparent !important;
            gap: 4px !important;
        }

    .crowdstrike-tab {
        padding: 6px 16px !important;
        font-weight: 500 !important;
        font-size: 0.85rem !important;
