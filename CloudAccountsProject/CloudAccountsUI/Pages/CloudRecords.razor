            : (cloudAccounts ?? new List<CloudAccountDetailsDTO>()).Where(x =>
                string.Equals(x.Provider, selectedProvider, StringComparison.OrdinalIgnoreCase));

    private List<ColumnDefinition> AvailableColumns = new()
