    public class ColumnDefinition
    {
        public string Title { get; set; } = string.Empty;
        public string GenericKey { get; set; } = string.Empty;
        public string PropertyName { get; set; } = string.Empty;
        public bool IsVisible { get; set; } = true;
        public bool IsStickyLeft { get; set; } = false;
    }

    // Helper method to get property expression for PropertyColumn
    private System.Linq.Expressions.Expression<Func<CloudAccountDetailsDTO, object>> GetPropertyExpression(string propertyName)
    {
        var parameter = System.Linq.Expressions.Expression.Parameter(typeof(CloudAccountDetailsDTO), "x");
        var property = System.Linq.Expressions.Expression.Property(parameter, propertyName);
        var conversion = System.Linq.Expressions.Expression.Convert(property, typeof(object));
        return System.Linq.Expressions.Expression.Lambda<Func<CloudAccountDetailsDTO, object>>(conversion, parameter);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            var result = await CloudRecordsService.GetCloudAccountDetailsAsync();
            cloudAccounts = result.CloudAccounts ?? new List<CloudAccountDetailsDTO>();
            columnMetadata = result.ColumnMetadata ?? new List<CloudAccountColumnMetadata>();
            businessFunctions = await BusinessFunctionService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
            cloudAccounts = new List<CloudAccountDetailsDTO>();
            columnMetadata = new List<CloudAccountColumnMetadata>();
            businessFunctions = new List<BusinessFunctionMaster>();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private Task<IEnumerable<BusinessFunctionMaster>> SearchBusinessFunctions(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(businessFunctions.AsEnumerable());

        return Task.FromResult(
            businessFunctions.Where(x =>
                !string.IsNullOrWhiteSpace(x.BusinessFunctionName) &&
                x.BusinessFunctionName.Contains(value, StringComparison.OrdinalIgnoreCase))
        );
    }

    private void OnBusinessFunctionChanged(BusinessFunctionMaster? value)
    {
        selectedBusinessFunction = value;

        if (editingAccount is null || value is null)
            return;

        editingAccount.BusinessFunctionId = value.Id;
    }

    private string GetColumnTitle(string genericKey)
    {
        if (columnMetadata == null || !columnMetadata.Any())
            return genericKey;

        var metadata = columnMetadata.FirstOrDefault(x => x.GenericColumn == genericKey);

        if (metadata == null)
            return genericKey;

        return selectedProvider switch
        {
            "AWS" => !string.IsNullOrWhiteSpace(metadata.AwsColumn) ? metadata.AwsColumn :
                     !string.IsNullOrWhiteSpace(metadata.AllColumn) ? metadata.AllColumn : genericKey,
            "Azure" => !string.IsNullOrWhiteSpace(metadata.AzureColumn) ? metadata.AzureColumn :
                       !string.IsNullOrWhiteSpace(metadata.AllColumn) ? metadata.AllColumn : genericKey,
            "GCP" => !string.IsNullOrWhiteSpace(metadata.GcpColumn) ? metadata.GcpColumn :
                     !string.IsNullOrWhiteSpace(metadata.AllColumn) ? metadata.AllColumn : genericKey,
            _ => !string.IsNullOrWhiteSpace(metadata.AllColumn) ? metadata.AllColumn : genericKey
        };
    }

    private bool ShouldHideColumn(string genericKey)
    {
        if (selectedProvider == "All")
            return false;

        var metadata = columnMetadata.FirstOrDefault(x => x.GenericColumn == genericKey);
        if (metadata == null)
            return false;

        return selectedProvider switch
        {
            "AWS" => string.IsNullOrWhiteSpace(metadata.AwsColumn),
            "Azure" => string.IsNullOrWhiteSpace(metadata.AzureColumn),
            "GCP" => string.IsNullOrWhiteSpace(metadata.GcpColumn),
            _ => false
        };
    }

    private List<ColumnDefinition> GetVisibleColumns()
    {
        return AvailableColumns
            .Where(x => x.IsVisible && !ShouldHideColumn(x.GenericKey))
            .Select(x => new ColumnDefinition
            {
                Title = GetColumnTitle(x.GenericKey),
                PropertyName = x.PropertyName,
                IsStickyLeft = x.IsStickyLeft,
                GenericKey = x.GenericKey,
                IsVisible = x.IsVisible
            })
            .ToList();
    }

    private object? GetPropertyValue(CloudAccountDetailsDTO item, string propertyName)
    {
        if (item == null) return null;

        var property = typeof(CloudAccountDetailsDTO).GetProperty(propertyName);
        if (property == null) return null;

        var value = property.GetValue(item);

        // Format DateTime values
        if (value is DateTime dateTime)
        {
            return dateTime.ToString("yyyy-MM-dd HH:mm");
        }

        return value;
    }

