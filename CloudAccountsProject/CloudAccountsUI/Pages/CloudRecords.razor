@page "/cloudrecords"
@using System.Net.Http.Json
@using CloudAccountsShared.Models
@using CloudAccountsShared.Models.DTOs
@using CloudAccountsUI.Dialogs.AuditDialogs
@using CloudAccountsUI.Services
@using CloudAccountsUI.Services.Contracts
@using MudBlazor
@inject ICloudRecordsService CloudRecordsService
@inject ICloudHistoryService CloudHistoryService
@inject IDialogService DialogService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject IBusinessFunctionService BusinessFunctionService

<div class="full-page-container">
    <div class="main-wrapper @(drawerOpen && !drawerFullscreen ? "drawer-open" : "") @(drawerFullscreen ? "fullscreen-active" : "")">
        <div class="pushed-content">
            <div class="header-toolbar">
                <div class="title-section">
                    <div class="cs-title">
                        <MudIcon Icon="@Icons.Material.Filled.Cloud" Class="mr-2" Style="color: #00A3FF;" />
                        Cloud Accounts Management
                    </div>
                    <div class="cs-subtitle">
                        Manage and monitor all your cloud accounts across providers
                    </div>
                </div>
                <div class="actions-section">
                    <MudTooltip Text="Export To CSV" Arrow="true" Placement="Placement.Top">
                        <MudIconButton Icon="@Icons.Material.Filled.Download"
                                       Style="color: #5A6A85;"
                                       Size="Size.Small"
                                       OnClick="ExportCsv" />
                    </MudTooltip>
                    <MudTooltip Text="Column Settings" Arrow="true" Placement="Placement.Top">
                        <MudIconButton Icon="@Icons.Material.Filled.Settings"
                                       Style="color: #5A6A85;"
                                       Size="Size.Small"
                                       OnClick="OpenColumnSelector" />
                    </MudTooltip>
                </div>
            </div>

            <div class="tabs-container">
                <MudTabs Rounded="true"
                         Elevation="0"
                         Class="crowdstrike-tabs"
                         ActivePanelIndexChanged="OnTabChanged">

                    <MudTabPanel Text="@AllTabText" Class="crowdstrike-tab" />
                    <MudTabPanel Text="@AwsTabText" Class="crowdstrike-tab" />
                    <MudTabPanel Text="@AzureTabText" Class="crowdstrike-tab" />
                    <MudTabPanel Text="@GcpTabText" Class="crowdstrike-tab" />
                </MudTabs>
            </div>

            <div class="grid-container">
                @if (isLoading)
                {
                    <div style="display: flex; justify-content: center; align-items: center; height: 400px;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                    </div>
                }
                else if (cloudAccounts.Count == 0)
                {
                    <div style="display: flex; justify-content: center; align-items: center; height: 400px; flex-direction: column;">
                        <MudIcon Icon="@Icons.Material.Filled.CloudOff" Size="Size.Large" Style="color: #CBD5E1; margin-bottom: 16px;" />
                        <MudText Typo="Typo.h6" Style="color: #5A6A85;">No cloud accounts found</MudText>
                        <MudText Typo="Typo.body2" Style="color: #94A3B8; margin-top: 8px;">No data available for the selected provider</MudText>
                    </div>
                }
                else
                {
                    <MudDataGrid T="CloudAccountDetailsDTO"
                                 @ref="_dataGrid"
                                 Items="@FilteredAccounts"
                                 Dense="true"
                                 Hover="true"
                                 Bordered="true"
                                 Striped="true"
                                 Filterable="true"
                                 FilterMode="DataGridFilterMode.ColumnFilterRow"
                                 FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive"
                                 ShowColumnOptions="false"
                                 FixedHeader="true"
                                 @bind-PageSize="PageSize"
                                 RowsPerPageOptions="@PageSizeOptions"
                                 Height="100%"
                                 Width="100%"
                                 Loading="@isLoading"
                                 ColumnResizeMode="ResizeMode.Column"
                                 DragDropColumnReordering="true"
                                 ColumnsPanelReordering="true"
                                 ShowMenuIcon="false"
                                 RowContextMenuClick="OpenContextMenu">

                        <Columns>
                            @* Dynamically generate columns based on metadata *@
                            @foreach (var columnConfig in GetVisibleColumns())
                            {
                                @* Special handling for Cloud Account ID column to add edit button *@
                                if (columnConfig.GenericKey == "CloudAccountId")
                                {
                                    <TemplateColumn Title="@columnConfig.Title" Resizable="true" StickyLeft="@columnConfig.IsStickyLeft">
                                        <CellTemplate Context="cell">
                                            <div class="cloud-account-id-cell">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small"
                                                               Class="edit-button-inline"
                                                               OnClick="() => OpenDrawer(cell.Item)"
                                                               Style="color: #00A3FF; margin-right: 8px;" />
                                                <div class="cell-content">
                                                    @{
                                                        var value = GetPropertyValue(cell.Item, columnConfig.PropertyName);
                                                    }
                                                    @if (value != null)
                                                    {
                                                        <MudTooltip Text="@value.ToString()" Placement="Placement.Top">
                                                            <span class="truncate-text">@value</span>
                                                        </MudTooltip>
                                                    }
                                                    else
                                                    {
                                                        <span>-</span>
                                                    }
                                                </div>
                                            </div>
                                        </CellTemplate>
                                    </TemplateColumn>
                                }
                                else
                                {
                                    <TemplateColumn Title="@columnConfig.Title" Resizable="true" StickyLeft="@columnConfig.IsStickyLeft">
                                        <CellTemplate Context="cell">
                                            <div class="cell-content">
                                                @{
                                                    var value = GetPropertyValue(cell.Item, columnConfig.PropertyName);
                                                }
                                                @if (value != null)
                                                {
                                                    <MudTooltip Text="@value.ToString()" Placement="Placement.Top">
                                                        <span class="truncate-text">@value</span>
                                                    </MudTooltip>
                                                }
                                                else
                                                {
                                                    <span>-</span>
                                                }
                                            </div>
                                        </CellTemplate>
                                    </TemplateColumn>
                                }
                            }
                        </Columns>

                        <NoRecordsContent>
                            <MudText Class="pa-4" Style="color: #5A6A85;">No matching records found</MudText>
                        </NoRecordsContent>

                        <PagerContent>
                            <MudDataGridPager T="CloudAccountDetailsDTO" PageSizeOptions="@PageSizeOptions" />
                        </PagerContent>
                    </MudDataGrid>
                }
            </div>
        </div>
    </div>

    <!-- Drawer HTML -->
    <div class="drawer-container @(drawerOpen ? "open" : "") @(drawerFullscreen ? "fullscreen" : "")">
        @if (drawerOpen && editingAccount is not null)
        {
            <div class="drawer-content">
                <div class="drawer-header">
                    <div class="drawer-title">Edit Cloud Account</div>
                    <div class="drawer-buttons">
                        <MudIconButton Icon="@(drawerFullscreen ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                                       Size="Size.Medium"
                                       Color="Color.Default"
                                       OnClick="ToggleFullscreen" />
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Size="Size.Medium"
                                       Color="Color.Default"
                                       OnClick="CloseDrawer" />
                    </div>
                </div>

                <div style="flex: 1; overflow-y: auto; padding-right: 8px;">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.subtitle2" Style="color: #1A1D2E; font-size: 13px; font-weight: 600;">Cloud Details</MudText>

                        <MudTextField T="string"
                                      Label="Provider"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.Provider"
                                      Disabled="true"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Cloud Account ID"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.CloudAccountId"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Cloud Name"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.CloudName"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Cloud Org ID"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.CloudOrgId"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Cloud Root Account ID"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.CloudRootAccountID"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Registration Type"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.RegistrationType"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Deployment Method"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.DeploymentMethod"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Registered At CRWD"
                                      Variant="Variant.Outlined"
                                      Value="@(editingAccount.RegisteredAtCRWD?.ToString("yyyy-MM-dd HH:mm") ?? "-")"
                                      Disabled="true"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Last Updated At CRWD"
                                      Variant="Variant.Outlined"
                                      Value="@(editingAccount.LastUpdatedAtCRWD?.ToString("yyyy-MM-dd HH:mm") ?? "-")"
                                      Disabled="true"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="IOM Status"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.IOMStatus"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="RTVD Status"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.RealTimeVisibilityAndDetectionStatus"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="1-Click Sensor Status"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.OneClickSensorStatus"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Identity Protection Status"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.IdentityProtectionStatus"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="DSPM Status"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.DSPMStatus"
                                      Dense="true" />

                        <MudTextField T="string"
                                      Label="Vulnerability Scanning Status"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.VulnerabilityScanningStatus"
                                      Dense="true" />

                        <MudDivider Class="my-3" />

                        <MudText Typo="Typo.subtitle2" Style="color: #1A1D2E; font-size: 13px; font-weight: 600;">Business Function</MudText>

                        <MudAutocomplete T="BusinessFunctionMaster"
                                         Label="Business Function Name"
                                         Variant="Variant.Outlined"
                                         Dense="true"
                                         Value="selectedBusinessFunction"
                                         ValueChanged="OnBusinessFunctionChanged"
                                         SearchFunc="SearchBusinessFunctions"
                                         ToStringFunc="@(x => x?.BusinessFunctionName ?? string.Empty)"
                                         Clearable="false" />

                        <MudTextField T="string"
                                      Label="Owner"
                                      Variant="Variant.Outlined"
                                      Value="selectedBusinessFunction?.BusinessFunctionOwner"
                                      Dense="true"
                                      Disabled="true" />

                        <MudTextField T="string"
                                      Label="LT Member"
                                      Variant="Variant.Outlined"
                                      Value="selectedBusinessFunction?.BusinessFunctionLtMember"
                                      Dense="true"
                                      Disabled="true" />

                        <MudTextField T="string"
                                      Label="SPOC"
                                      Variant="Variant.Outlined"
                                      Value="selectedBusinessFunction?.BusinessFunctionSpoc"
                                      Dense="true"
                                      Disabled="true" />

                        <MudTextField T="string"
                                      Label="Business Tag Value"
                                      Variant="Variant.Outlined"
                                      Value="selectedBusinessFunction?.BusinessTagValue"
                                      Dense="true"
                                      Disabled="true" />

                        <MudTextField T="string"
                                      Label="Business Function Remarks"
                                      Variant="Variant.Outlined"
                                      Value="selectedBusinessFunction?.Remarks"
                                      Dense="true"
                                      Disabled="true" />

                        <MudDivider Class="my-3" />

                        <MudText Typo="Typo.subtitle2" Style="color: #1A1D2E; font-size: 13px; font-weight: 600;">Manual Details</MudText>

                        <MudSelect T="string"
                                   Label="Account Type"
                                   Variant="Variant.Outlined"
                                   @bind-Value="editingAccount.AccountType"
                                   Dense="true">

                            <MudSelectItem Value='"Hybrid"'>Hybrid</MudSelectItem>
                            <MudSelectItem Value='"Managed"'>Managed</MudSelectItem>
                            <MudSelectItem Value='"Self - Managed"'>Self-Managed</MudSelectItem>
                            <MudSelectItem Value='"Sandbox"'>Sandbox</MudSelectItem>
                            <MudSelectItem Value='"SingleAccount"'>SingleAccount</MudSelectItem>
                        </MudSelect>

                        <MudSelect T="string"
                                   Label="Overall Status"
                                   Variant="Variant.Outlined"
                                   @bind-Value="editingAccount.OverallStatus"
                                   Dense="true">

                            <MudSelectItem Value='"Active"'>Active</MudSelectItem>
                            <MudSelectItem Value='"Deleted"'>Deleted</MudSelectItem>
                            <MudSelectItem Value='"Disabled"'>Disabled</MudSelectItem>
                        </MudSelect>

                        <MudTextField T="string"
                                      Label="Manual Remarks"
                                      Variant="Variant.Outlined"
                                      Lines="3"
                                      @bind-Value="editingAccount.ManualRemarks" />

                        <MudTextField T="string"
                                      Label="Attachment Path"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingAccount.AttachmentPath"
                                      Dense="true" />
                    </MudStack>
                </div>

                <div class="drawer-footer">
                    <MudButton Variant="Variant.Text"
                               OnClick="CloseDrawer"
                               Style="color: #5A6A85;">
                        Cancel
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Style="background: #00A3FF; color: white; font-weight: 600;"
                               OnClick="SaveEdit"
                               Disabled="@isSaving">
                        @if (isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                            <span class="ml-2">Saving...</span>
                        }
                        else
                        {
                            <span>Save</span>
                        }
                    </MudButton>
                </div>
            </div>
        }
    </div>
</div>

@if (showColumnDialog)
{
    <div class="overlay" @onclick="CloseColumnSelector"></div>
    <div class="column-selector-dialog" style="width: 400px; max-width: 90%;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <MudText Typo="Typo.h6" Style="color: #1A1D2E; font-weight: 600;">
                Select & Reorder Columns - @(selectedProvider == "All" ? "All Providers" : selectedProvider)
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CloseColumnSelector" Style="color: #5A6A85;" />
        </div>
        <MudText Typo="Typo.body2" Style="color: #5A6A85; margin-bottom: 12px; font-size: 12px;">
            Use ↑ ↓ buttons to reorder columns
        </MudText>
        <MudDivider Class="mb-3" />
        <div style="max-height: 400px; overflow-y: auto;">
            @if (tempColumnSelectorItems != null && tempColumnSelectorItems.Any())
            {
                @for (int i = 0; i < tempColumnSelectorItems.Count; i++)
                {
                    var column = tempColumnSelectorItems[i];
                    var currentIndex = i;
                    <div class="column-item" style="display: flex; align-items: center; padding: 8px; margin-bottom: 4px; background: #F8F9FC; border-radius: 6px;">
                        <div style="display: flex; flex-direction: column; margin-right: 8px;">
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                                           Size="Size.Small"
                                           OnClick="() => MoveColumnUp(currentIndex)"
                                           Disabled="@(currentIndex == 0)"
                                           Style="padding: 2px;" />
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward"
                                           Size="Size.Small"
                                           OnClick="() => MoveColumnDown(currentIndex)"
                                           Disabled="@(currentIndex == tempColumnSelectorItems.Count - 1)"
                                           Style="padding: 2px; margin-top: 2px;" />
                        </div>
                        <input type="checkbox"
                               id="@column.GenericKey"
                               @bind="column.IsVisible"
                               style="margin-right: 8px; cursor: pointer; width: 16px; height: 16px; accent-color: #00A3FF;"
                               @onclick:stopPropagation="true" />
                        <label for="@column.GenericKey" style="flex: 1; font-size: 14px; color: #1A1D2E; cursor: pointer; margin: 0;">@column.DisplayTitle</label>
                    </div>
                }
            }
        </div>
        <MudDivider Class="mt-3 mb-3" />
        <div style="display: flex; justify-content: flex-end; gap: 8px;">
            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ResetColumns">Reset</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="ApplyColumnVisibility">Apply</MudButton>
        </div>
    </div>
}

<MudMenu PositionAtCursor="true" @ref="_contextMenu" id="_contextMenu">
    <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => EditFromContext())">
        Edit @_contextRow?.CloudName
    </MudMenuItem>
    <MudMenuItem Icon="@Icons.Material.Filled.Info" OnClick="@ShowAudits">
        View Audits for @_contextRow?.CloudAccountId
    </MudMenuItem>
</MudMenu>

<style>
    ::deep .mud-layout {
        padding: 0 !important;
        margin: 0 !important;
    }

    ::deep .mud-main-content {
        padding: 0 !important;
        margin: 0 !important;
    }

    .full-page-container {
        width: 100%;
        height: 100vh;
        padding: 0;
        margin: 0;
        overflow: hidden;
        background: white;
        display: flex;
        flex-direction: column;
    }

    .main-wrapper {
        flex: 1;
        display: flex;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .pushed-content {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .header-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid #E2E8F0;
        flex-shrink: 0;
        background: white;
    }

    .title-section {
        flex: 1;
    }

    .cs-title {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
        font-size: 20px;
        font-weight: 600;
        color: #1A1D2E;
        letter-spacing: -0.3px;
    }

    .cs-subtitle {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
        font-size: 13px;
        color: #5A6A85;
        margin-top: 4px;
    }

    .actions-section {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .tabs-container {
        flex-shrink: 0;
        padding: 0 20px;
        margin-bottom: 0;
    }

    .crowdstrike-tabs {
        background: transparent !important;
    }

        .crowdstrike-tabs .mud-tabs-toolbar {
            background: transparent !important;
            gap: 4px !important;
        }

    .crowdstrike-tab {
        padding: 8px 20px !important;
        font-weight: 500 !important;
        font-size: 0.9rem !important;
        color: #4a5568 !important;
        text-transform: none !important;
        border-radius: 8px !important;
        transition: all 0.2s ease !important;
    }

        .crowdstrike-tab:hover {
            background: rgba(0, 0, 0, 0.04) !important;
            color: #667eea !important;
        }

        .crowdstrike-tab.mud-tab-active {
            color: #667eea !important;
            font-weight: 600 !important;
            background: rgba(102, 126, 234, 0.08) !important;
        }

    .mud-tab-indicator {
        display: none !important;
    }

    .grid-container {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        min-height: 0;
        position: relative;
        padding: 20px;
    }

    .mud-table-container {
        max-height: calc(100vh - 280px) !important;
        overflow: auto !important;
        position: relative !important;
    }

    .mud-table {
        width: 100%;
    }

        .mud-table table {
            border-collapse: collapse;
            width: 100%;
        }

    .mud-table-head {
        position: sticky !important;
        top: 0 !important;
        z-index: 90 !important;
        background: #F8F9FC !important;
    }

        .mud-table-head .mud-table-cell {
            font-weight: 600 !important;
            white-space: nowrap !important;
            background: #F8F9FC !important;
            color: #1A1D2E !important;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
            font-size: 12px !important;
            letter-spacing: 0.3px;
            text-transform: uppercase;
            border-bottom: 1px solid #E2E8F0 !important;
        }

    .mud-table-body .mud-table-cell {
        color: #1A1D2E !important;
        border-bottom: 1px solid #EDF2F7 !important;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
        font-size: 13px;
    }

    .mud-table-body .mud-table-row:hover {
        background: #F8F9FC !important;
    }

    .mud-table-pagination {
        display: flex !important;
        justify-content: flex-end !important;
        align-items: center !important;
        width: 100% !important;
        padding: 8px 16px !important;
        background: white !important;
        border-top: 1px solid #E2E8F0 !important;
    }

    .drawer-container {
        width: 0;
        flex-shrink: 0;
        overflow: hidden;
        transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: white;
        border-left: 1px solid #E2E8F0;
        height: calc(100vh - 63px);
        position: fixed;
        right: 0;
        top: 63px;
        z-index: 1000;
    }

        .drawer-container.open {
            width: 50%;
            min-width: 500px;
            max-width: 700px;
        }

    .main-wrapper.drawer-open {
        margin-right: 50%;
        min-width: calc(100% - 700px);
        max-width: calc(100% - 500px);
    }

    .drawer-container.fullscreen {
        width: 100% !important;
        min-width: 100%;
        max-width: 100%;
        height: calc(100vh - 63px);
        top: 63px;
    }

    .main-wrapper.drawer-open.fullscreen-active {
        margin-right: 0 !important;
        display: none;
    }

    .drawer-content {
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-shrink: 0;
        padding-bottom: 10px;
        border-bottom: 1px solid #E2E8F0;
    }

    .drawer-title {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
        font-size: 18px;
        font-weight: 600;
        color: #1A1D2E;
    }

    .drawer-buttons {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .drawer-footer {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        padding-top: 16px;
        margin-top: 16px;
        border-top: 1px solid #E2E8F0;
        background: white;
        flex-shrink: 0;
    }

    .column-selector-dialog {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        z-index: 2000;
        width: 350px;
        max-width: 90%;
        padding: 20px;
        border: 1px solid #E2E8F0;
    }

    .overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1999;
    }

    .mud-switch {
        --mud-switch-checked-color: #00A3FF !important;
    }

        .mud-switch .mud-switch-track {
            background-color: #E2E8F0 !important;
        }

        .mud-switch .mud-switch-thumb {
            background-color: white !important;
        }

        .mud-switch.mud-switch-checked .mud-switch-track {
            background-color: #00A3FF !important;
        }

