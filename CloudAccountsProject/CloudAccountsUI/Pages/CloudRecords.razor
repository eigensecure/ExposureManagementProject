            Provider = account.Provider,
            CloudAccountId = account.CloudAccountId,
            CloudName = account.CloudName,
            CloudOrgId = account.CloudOrgId,
            CloudRootAccountID = account.CloudRootAccountID,
            RegistrationType = account.RegistrationType,
            DeploymentMethod = account.DeploymentMethod,
            RegisteredAtCRWD = account.RegisteredAtCRWD,
            LastUpdatedAtCRWD = account.LastUpdatedAtCRWD,
            IOMStatus = account.IOMStatus,
            RealTimeVisibilityAndDetectionStatus = account.RealTimeVisibilityAndDetectionStatus,
            OneClickSensorStatus = account.OneClickSensorStatus,
            IdentityProtectionStatus = account.IdentityProtectionStatus,
            DSPMStatus = account.DSPMStatus,
            VulnerabilityScanningStatus = account.VulnerabilityScanningStatus,
            BusinessFunctionId = account.BusinessFunctionId,
            BusinessFunctionName = account.BusinessFunctionName,
            BusinessFunctionLtMember = account.BusinessFunctionLtMember,
            BusinessFunctionOwner = account.BusinessFunctionOwner,
            BusinessFunctionSpoc = account.BusinessFunctionSpoc,
            BusinessFunctionRemarks = account.BusinessFunctionRemarks,
            BusinessTagValue = account.BusinessTagValue,
            ManualDetailsId = account.ManualDetailsId,
            AccountType = account.AccountType,
            OverallStatus = account.OverallStatus,
            ManualRemarks = account.ManualRemarks,
            AttachmentPath = account.AttachmentPath
        };

        selectedBusinessFunction = businessFunctions
            .FirstOrDefault(x => x.Id == editingAccount.BusinessFunctionId);

        drawerOpen = true;
        StateHasChanged();
    }

    private async Task UploadAttachment(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;

            if (file is null)
                return;

            var cloudAccountId = editingAccount.CloudAccountId ?? editingAccount.Id.ToString();

            var uploadedPath = await CloudRecordsService.UploadAttachmentAsync(
                file,
                cloudAccountId);

            editingAccount.AttachmentPath = uploadedPath;

            Snackbar.Add("File uploaded successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
        }
    }

    private void RemoveAttachment()
    {
        editingAccount.AttachmentPath = null;
    }

    private void CloseDrawer()
    {
        drawerOpen = false;
        drawerFullscreen = false;
        editingAccount = null;
        selectedBusinessFunction = null;
        StateHasChanged();
    }

    private async Task SaveEdit()
    {
        if (editingAccount is null)
            return;

        try
        {
            isSaving = true;
            StateHasChanged();

            await CloudRecordsService.SaveBusManDetailsAsync(editingAccount);
            await LoadData();

            Snackbar.Add("Cloud account details saved successfully", Severity.Success);
            CloseDrawer();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving data: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }
