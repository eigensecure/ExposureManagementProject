        display: flex;
        align-items: center;
        gap: 12px;
    }

    .cs-title {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
        font-size: 20px;
        font-weight: 600;
        color: #1A1D2E;
        letter-spacing: -0.3px;
    }

    .cs-subtitle {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
