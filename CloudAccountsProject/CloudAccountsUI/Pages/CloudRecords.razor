        }

    .mud-table-head {
        position: sticky !important;
        top: 0 !important;
        z-index: 90 !important;
        background: #F8F9FC !important;
    }

        .mud-table-head .mud-table-cell {
            font-weight: 600 !important;
            white-space: nowrap !important;
            background: #F8F9FC !important;
            color: #1A1D2E !important;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
            font-size: 12px !important;
            letter-spacing: 0.3px;
            text-transform: uppercase;
            border-bottom: 1px solid #E2E8F0 !important;
        }

    .mud-table-body .mud-table-cell {
        color: #1A1D2E !important;
        border-bottom: 1px solid #EDF2F7 !important;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
        font-size: 13px;
    }

    .mud-table-body .mud-table-row:hover {
        background: #F8F9FC !important;
    }

    .mud-table-pagination {
        display: flex !important;
        justify-content: flex-end !important;
        align-items: center !important;
        width: 100% !important;
        padding: 8px 16px !important;
        background: white !important;
        border-top: 1px solid #E2E8F0 !important;
    }

    .drawer-container {
        width: 0;
        flex-shrink: 0;
        overflow: hidden;
        transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: white;
        border-left: 1px solid #E2E8F0;
        height: calc(100vh - 63px);
        position: fixed;
        right: 0;
        top: 63px;
        z-index: 1000;
    }

        .drawer-container.open {
            width: 50%;
            min-width: 500px;
            max-width: 700px;
        }

    .main-wrapper.drawer-open {
        margin-right: 50%;
        min-width: calc(100% - 700px);
        max-width: calc(100% - 500px);
    }

    .drawer-container.fullscreen {
        width: 100% !important;
        min-width: 100%;
        max-width: 100%;
        height: calc(100vh - 63px);
        top: 63px;
    }

    .main-wrapper.drawer-open.fullscreen-active {
        margin-right: 0 !important;
        display: none;
    }

    .drawer-content {
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-shrink: 0;
        padding-bottom: 10px;
        border-bottom: 1px solid #E2E8F0;
    }

    .drawer-title {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
        font-size: 18px;
        font-weight: 600;
        color: #1A1D2E;
    }

    .drawer-buttons {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .drawer-footer {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        padding-top: 16px;
        margin-top: 16px;
        border-top: 1px solid #E2E8F0;
        background: white;
        flex-shrink: 0;
    }

    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #F1F5F9;
    }

    ::-webkit-scrollbar-thumb {
        background: #CBD5E1;
        border-radius: 4px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: #94A3B8;
        }

    .cell-content {
        width: 100%;
        white-space: normal;
        word-break: break-word;
        padding: 4px;
    }

    .truncate-text {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
        display: block;
    }

    /* Styles for cloud account ID cell with edit button */
    .cloud-account-id-cell {
        display: flex;
        align-items: center;
        width: 100%;
        gap: 8px;
    }

    .edit-button-inline {
        flex-shrink: 0;
        transition: all 0.2s ease;
    }

        .edit-button-inline:hover {
            transform: scale(1.1);
            background-color: rgba(0, 163, 255, 0.1) !important;
        }

    .cloud-account-id-cell .cell-content {
        flex: 1;
        min-width: 0;
        padding: 0;
    }
</style>

@code {
    private MudDataGrid<CloudAccountDetailsDTO> _dataGrid = null!;
    private MudMenu _contextMenu = null!;
    private CloudAccountDetailsDTO? _contextRow;

    private bool isLoading = true;
    private bool isSaving = false;
    private int PageSize = 10;
    private int[] PageSizeOptions = new[] { 10, 25, 50, 100 };

    private bool drawerOpen;
    private bool drawerFullscreen = false;

    private List<CloudAccountDetailsDTO> cloudAccounts = new();
    private List<CloudAccountColumnMetadata> columnMetadata = new();
    private List<BusinessFunctionMaster> businessFunctions = new();
    private BusinessFunctionMaster? selectedBusinessFunction;

    private CloudAccountDetailsDTO? editingAccount;

    private string selectedProvider = "All";

    private int AllCount => cloudAccounts?.Count ?? 0;
    private int AwsCount => cloudAccounts?.Count(x =>
        string.Equals(x.Provider, "aws", StringComparison.OrdinalIgnoreCase)) ?? 0;

    private int AzureCount => cloudAccounts?.Count(x =>
        string.Equals(x.Provider, "azure", StringComparison.OrdinalIgnoreCase)) ?? 0;

    private int GcpCount => cloudAccounts?.Count(x =>
        string.Equals(x.Provider, "gcp", StringComparison.OrdinalIgnoreCase)) ?? 0;

    private string AllTabText => $"All ({AllCount})";
    private string AwsTabText => $"AWS ({AwsCount})";
    private string AzureTabText => $"Azure ({AzureCount})";
    private string GcpTabText => $"GCP ({GcpCount})";

    private IEnumerable<CloudAccountDetailsDTO> FilteredAccounts =>
        selectedProvider == "All"
            ? cloudAccounts ?? new List<CloudAccountDetailsDTO>()
            : (cloudAccounts ?? new List<CloudAccountDetailsDTO>()).Where(x =>
                string.Equals(x.Provider, selectedProvider, StringComparison.OrdinalIgnoreCase));

    private List<ColumnDefinition> AvailableColumns = new()
    {
        new() { Title = "Provider", IsVisible = true, GenericKey = "Provider", PropertyName = "Provider", IsStickyLeft = false },
        new() { Title = "Cloud Account ID", IsVisible = true, GenericKey = "CloudAccountId", PropertyName = "CloudAccountId", IsStickyLeft = true },
