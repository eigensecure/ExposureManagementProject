@page "/crowdgroupmaster"
@using CloudAccountsShared.Models
@using CloudAccountsUI.Services.Contracts
@using CloudAccountsUI.Dialogs.AuditDialogs
@using System.Net.Http.Json
@using CloudAccountsShared.Configuration.Services.Contracts
@inject ITableConfigService TableConfigService
@inject ICrowdGroupMasterService CrowdGroupService
@inject ICloudHistoryService CloudHistoryService
@inject IBusinessFunctionService BusinessFunctionService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<div class="full-page-container">
    <div class="main-wrapper @(drawerOpen && !drawerFullscreen ? "drawer-open" : "") @(drawerFullscreen ? "fullscreen-active" : "")">
        <div class="pushed-content">

            <div class="grid-container">
                @if (isLoading)
                {
                    <div style="display: flex; justify-content: center; align-items: center; height: 400px;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                    </div>
                }
                else if (groups.Count != 0)
                {
                    <div class="data-grid-wrapper">
                        <MudDataGrid T="CrowdGroupMaster"
                                     @ref="_dataGrid"
                                     Items="@groups"
                                     Dense="true"
                                     Hover="true"
                                     Bordered="true"
                                     Striped="true"
                                     Filterable="true"
                                     FilterMode="DataGridFilterMode.ColumnFilterRow"
                                     FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive"
                                     FixedHeader="true"
                                     FixedFooter="true"
                                     @bind-PageSize="PageSize"
                                     RowsPerPageOptions="@PageSizeOptions"
                                     Width="100%"
                                     RowContextMenuClick="OpenContextMenu"
                                     DragDropColumnReordering="true"
                                     ColumnsPanelReordering="true"
                                     ColumnResizeMode="ResizeMode.Container"
                                     ShowMenuIcon="true">

                            <ToolBarContent>
                                <div class="d-flex flex-column">
                                    <MudText Typo="Typo.h6" Class="d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.Groups"
                                                 Class="mr-2"
                                                 Style="color: #00A3FF;" />
                                        Crowd Groups Master
                                    </MudText>

                                    <MudText Typo="Typo.body2" Class="text-secondary">
                                        Manage and monitor all your crowd groups across providers
                                    </MudText>
                                </div>

                                <MudSpacer />

                                <MudButton Variant="Variant.Text"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="OpenAddDrawer">
                                    Add Group
                                </MudButton>
                            </ToolBarContent>

                            <Columns>
                                @if (viewableColumns.Contains(nameof(CrowdGroupMaster.CrwdgroupName)))
                                {
                                    <PropertyColumn Property="x => x.CrwdgroupName"
                                                    Title="CRWD Group Name"
                                                    Width="240px"
                                                    Resizable="true"
                                                    Hideable="true"
                                                    StickyLeft="true"
                                                    HeaderStyle="white-space: nowrap; position: sticky; left: 0; background: #F8F9FC; z-index: 10;"
                                                    CellStyle="position: sticky; left: 0; background: white; z-index: 5;">
                                        <CellTemplate Context="context">
                                            <div class="crowd-group-name-cell">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small"
                                                               Class="edit-button-inline"
                                                               OnClick="() => EditGroup(context.Item)"
                                                               Style="color: #00A3FF; margin-right: 8px;" />

                                                <MudTooltip Text="@context.Item.CrwdgroupName" Placement="Placement.Top">
                                                    <span class="truncate-text">@context.Item.CrwdgroupName</span>
                                                </MudTooltip>
                                            </div>
                                        </CellTemplate>
                                    </PropertyColumn>
                                }

                                @if (viewableColumns.Contains(nameof(CrowdGroupMaster.GroupType)))
                                {
                                    <PropertyColumn Property="x => x.GroupType" Title="Group Type" Resizable="true" Hideable="true" />
                                }
                                @if (viewableColumns.Contains(nameof(CrowdGroupMaster.GroupId)))
                                {
                                    <PropertyColumn Property="x => x.GroupId" Title="Group ID" Resizable="true" Hideable="true" />
                                }
                                @if (viewableColumns.Contains(nameof(CrowdGroupMaster.Provider)))
                                {
                                    <PropertyColumn Property="x => x.Provider" Title="Provider" Resizable="true" Hideable="true" />
                                }
                                @if (viewableColumns.Contains(nameof(CrowdGroupMaster.BusinessFunction.BusinessFunctionName)))
                                {
                                    <PropertyColumn Property="x => x.BusinessFunction.BusinessFunctionName" Title="Business Function" Resizable="true" Hideable="true" />
                                }
                                @if (viewableColumns.Contains(nameof(CrowdGroupMaster.AllAccountIds)))
                                {
                                    <PropertyColumn Property="x => x.AllAccountIds" Title="All Account IDs" Resizable="true" Hideable="true" />
                                }
                                @if (viewableColumns.Contains(nameof(CrowdGroupMaster.DateCreated)))
                                {
                                    <PropertyColumn Property="x => x.DateCreated" Title="Created Date" Resizable="true" Hideable="true">

                                        <CellTemplate Context="cell">
                                            <span>@(cell.Item.DateCreated == default ? "-" : cell.Item.DateCreated.ToString("dd MMM yyyy, hh:mm tt"))</span>
                                        </CellTemplate>
                                    </PropertyColumn>
                                }
                                @if (viewableColumns.Contains(nameof(CrowdGroupMaster.DateModified)))
                                {
                                    <PropertyColumn Property="x => x.DateModified" Title="Updated Date" Resizable="true" Hideable="true">
                                        <CellTemplate Context="cell">
                                            <span>@(cell.Item.DateModified == default ? "-" : cell.Item.DateModified.ToString("dd MMM yyyy, hh:mm tt"))</span>
                                        </CellTemplate>
                                    </PropertyColumn>
                                }
                            </Columns>

                            <NoRecordsContent>
                                <MudText Class="pa-4" Style="color: #5A6A85;">No matching records found</MudText>
                            </NoRecordsContent>


                            <PagerContent>
                                <MudDataGridPager T="CrowdGroupMaster" />
                            </PagerContent>
                        </MudDataGrid>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column" style="height: calc(100vh - 170px); padding: 20px;">

                        <div class="d-flex align-center mb-4">
                            <div class="d-flex flex-column">
                                <MudText Typo="Typo.h6" Class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Groups"
                                             Class="mr-2"
                                             Style="color: #00A3FF;" />
                                    Crowd Groups Master
                                </MudText>

                                <MudText Typo="Typo.body2" Class="text-secondary">
                                    Manage and monitor all your crowd groups across providers
                                </MudText>
                            </div>

                            <MudSpacer />

                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="OpenAddDrawer">
                                Add Group
                            </MudButton>
                        </div>

                        <div class="d-flex flex-column align-center justify-center flex-grow-1">
                            <MudIcon Icon="@Icons.Material.Filled.Groups"
                                     Size="Size.Large"
                                     Style="color: #CBD5E1; margin-bottom: 16px;" />

                            <MudText Typo="Typo.h6" Style="color: #5A6A85;">
                                No crowd groups found
                            </MudText>

                            <MudText Typo="Typo.body2" Style="color: #94A3B8; margin-top: 8px;">
                                Click "Add Group" to create your first crowd group
                            </MudText>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Context Menu *@
    <MudMenu PositionAtCursor="true" @ref="_contextMenu" id="_contextMenu">
        <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => EditFromContext())">
            Edit @_contextRow?.CrwdgroupName
        </MudMenuItem>
        @* <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="@(() => DeleteFromContext())">
            Delete @_contextRow?.CrwdgroupName
        </MudMenuItem> *@
        @* <MudMenuItem Icon="@Icons.Material.Filled.Sync" OnClick="@(() => PatchSelectedGroup())">
            Patch @_contextRow?.CrwdgroupName
        </MudMenuItem> *@
        <MudMenuItem Icon="@Icons.Material.Filled.Info" OnClick="@(() => ShowAudits())">
            View Audits @_contextRow?.CrwdgroupName
        </MudMenuItem>
    </MudMenu>

    @* Drawer *@
    <div class="drawer-container @(drawerOpen ? "open" : "") @(drawerFullscreen ? "fullscreen" : "")">
        @if (drawerOpen)
        {
            <div class="drawer-content">
                <div class="drawer-header">
                    <div class="drawer-title">@(isEdit ? "Edit Crowd Group" : "Add Crowd Group")</div>
                    <div class="drawer-buttons">
                        <MudIconButton Icon="@(drawerFullscreen ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                                       Size="Size.Medium"
                                       Color="Color.Default"
                                       OnClick="ToggleFullscreen" />
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Size="Size.Medium"
                                       Color="Color.Default"
                                       OnClick="CloseDrawer" />
                    </div>
                </div>

                <div style="flex: 1; overflow-y: auto; padding-right: 8px;">
                    <MudStack Spacing="2">
                        @if (CanView(nameof(CrowdGroupMaster.CrwdgroupName)))
                        {
                            <MudTextField T="string"
                                          Label="CRWD Group Name"
                                          Variant="Variant.Outlined"
                                          @bind-Value="editingGroup.CrwdgroupName"
                                          Dense="true"
                                          Required="true"
                                          Disabled="@(!CanEdit(nameof(CrowdGroupMaster.CrwdgroupName)))" />
                        }

                        @if (CanView(nameof(CrowdGroupMaster.GroupType)))
                        {
                            <MudSelect T="string"
                                       Label="Group Type"
                                       Variant="Variant.Outlined"
                                       @bind-Value="editingGroup.GroupType"
                                       Dense="true"
                                       Required="true"
                                       Disabled="@(!CanEdit(nameof(CrowdGroupMaster.GroupType)))">
                                <MudSelectItem Value="@("Host_Group")">Host_Group</MudSelectItem>
                                <MudSelectItem Value="@("Cloud_Group")">Cloud_Group</MudSelectItem>
                            </MudSelect>
                        }

                        @if (CanView(nameof(CrowdGroupMaster.GroupId)))
                        {
                            <MudTextField T="string"
                                          Label="Group ID"
                                          Variant="Variant.Outlined"
                                          @bind-Value="editingGroup.GroupId"
                                          Dense="true"
                                          Required="true"
                                          Disabled="@(!CanEdit(nameof(CrowdGroupMaster.GroupId)))" />
                        }

                        @if (CanView(nameof(CrowdGroupMaster.Provider)))
                        {
                            <MudSelect T="string"
                                       Label="Provider"
                                       Variant="Variant.Outlined"
                                       Value="editingGroup.Provider"
                                       ValueChanged="OnProviderChanged"
                                       Dense="true"
                                       Required="true"
                                       Disabled="@(!CanEdit(nameof(CrowdGroupMaster.Provider)))">
                                <MudSelectItem Value="@("AWS")">AWS</MudSelectItem>
                                <MudSelectItem Value="@("Azure")">Azure</MudSelectItem>
                                <MudSelectItem Value="@("GCP")">GCP</MudSelectItem>
                            </MudSelect>
                        }

                        @if (CanView(nameof(CrowdGroupMaster.BusinessFunction.BusinessFunctionName)))
                        {
                            <MudAutocomplete T="BusinessFunctionMaster"
                                             Label="Business Function"
                                             Variant="Variant.Outlined"
                                             Dense="true"
                                             Required="true"
                                             Disabled="@(!CanEdit(nameof(CrowdGroupMaster.BusinessFunction.BusinessFunctionName)))"
                                             Value="selectedBusinessFunction"
                                             ValueChanged="OnBusinessFunctionChanged"
                                             SearchFunc="SearchBusinessFunctions"
                                             ToStringFunc="@(x => x?.BusinessFunctionName ?? string.Empty)"
                                             Clearable="false" />
                        }

                        @if (CanView(nameof(CrowdGroupMaster.AllAccountIds)))
                        {
                            <MudTextField T="string"
                                          Label="All Account IDs"
                                          Variant="Variant.Outlined"
                                          @bind-Value="editingGroup.AllAccountIds"
                                          Dense="true"
                                          HelperText="Comma-separated account IDs"
                                          Lines="2"
                                          Disabled="@(!CanEdit(nameof(CrowdGroupMaster.AllAccountIds)))" />
                        }

                        @if (CanView(nameof(CrowdGroupMaster.Remarks)))
                        {
                            <MudTextField T="string"
                                          Label="Remarks"
                                          Variant="Variant.Outlined"
                                          @bind-Value="editingGroup.Remarks"
                                          Lines="3"
                                          Dense="true"
                                          Disabled="@(!CanEdit(nameof(CrowdGroupMaster.Remarks)))" />
                        }
                    </MudStack>
                </div>

                <div class="drawer-footer">
                    <MudButton Variant="Variant.Text"
                               OnClick="CloseDrawer"
                               Style="color: #5A6A85;">
                        Cancel
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Style="background: #00A3FF; color: white; font-weight: 600;"
                               OnClick="SaveGroup"
                               Disabled="@isSaving">
                        @if (isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                            <span class="ml-2">Saving...</span>
                        }
                        else
                        {
                            <span>Save</span>
                        }
                    </MudButton>
                </div>
            </div>
        }
    </div>
</div>

