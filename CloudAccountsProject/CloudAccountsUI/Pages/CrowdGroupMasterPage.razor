        height: calc(100vh - 63px);
        top: 63px;
    }

    .main-wrapper.drawer-open.fullscreen-active {
        margin-right: 0 !important;
        display: none;
    }

    .drawer-content {
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-shrink: 0;
        padding-bottom: 10px;
        border-bottom: 1px solid #E2E8F0;
    }

    .drawer-title {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
        font-size: 18px;
        font-weight: 600;
