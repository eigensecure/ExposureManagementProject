@code {
    private MudDataGrid<CrowdGroupMaster> _dataGrid = null!;
    private MudMenu _contextMenu = null!;
    private CrowdGroupMaster? _contextRow;

    private List<CrowdGroupMaster> groups = new();
    private List<BusinessFunctionMaster> businessFunctions = new();
    private BusinessFunctionMaster? selectedBusinessFunction;
    private List<string> viewableColumns = new();
    private List<string> editableColumns = new();


    private bool isLoading = true;
    private bool isSaving = false;
    private bool drawerOpen = false;
    private bool drawerFullscreen = false;
    private bool isEdit = false;
    private int PageSize = 10;
    private int[] PageSizeOptions = new[] { 10, 25, 50, 100 };
    private CrowdGroupMaster editingGroup = new();
    private bool CanView(string columnName)
        => viewableColumns.Contains(columnName) || editableColumns.Contains(columnName);

    private bool CanEdit(string columnName)
        => editableColumns.Contains(columnName);


    protected override async Task OnInitializedAsync()
    {
        viewableColumns = TableConfigService
        .GetViewableColumns(nameof(CrowdGroupMaster))
        .ToList();

        editableColumns = TableConfigService
            .GetEditableColumns(nameof(CrowdGroupMaster))
            .ToList();
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            await Task.WhenAll(LoadGroups(), LoadBusinessFunctions());
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadGroups()
    {
        try
        {
            groups = await CrowdGroupService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading groups: {ex.Message}", Severity.Error);
            groups = new List<CrowdGroupMaster>();
        }
    }

    private async Task LoadBusinessFunctions()
    {
        try
        {
            businessFunctions = await BusinessFunctionService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading business functions: {ex.Message}", Severity.Error);
            businessFunctions = new List<BusinessFunctionMaster>();
        }
    }

    private Task<IEnumerable<BusinessFunctionMaster>> SearchBusinessFunctions(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(businessFunctions.AsEnumerable());

        return Task.FromResult(
            businessFunctions.Where(x =>
                !string.IsNullOrWhiteSpace(x.BusinessFunctionName) &&
                x.BusinessFunctionName.Contains(value, StringComparison.OrdinalIgnoreCase))
        );
    }

    private async Task OnBusinessFunctionChanged(BusinessFunctionMaster? value)
    {
        selectedBusinessFunction = value;

        if (value is null)
        {
            editingGroup.BusinessFunctionId = null;
            editingGroup.AllAccountIds = string.Empty;
            return;
        }

        editingGroup.BusinessFunctionId = value.Id;

        await RefreshAllAccountIds();
    }

    private async Task OnProviderChanged(string value)
    {
        editingGroup.Provider = value;

        await RefreshAllAccountIds();
    }

    private async Task RefreshAllAccountIds()
    {
        if (editingGroup.BusinessFunctionId.HasValue &&
            !string.IsNullOrWhiteSpace(editingGroup.Provider))
        {
            editingGroup.AllAccountIds = await CrowdGroupService.GetAllAccountIdsAsync(
                editingGroup.BusinessFunctionId.Value,
                editingGroup.Provider);

            StateHasChanged();
        }
    }

    // private async Task PatchSelectedGroup()
    // {
    //     if (_contextRow is null)
    //         return;

    //     try
    //     {
    //         await CrowdGroupService.PatchGroupAsync(_contextRow.Id);

    //         Snackbar.Add(
    //             $"Patched {_contextRow.CrwdgroupName} successfully",
    //             Severity.Success);

    //         await LoadData();
    //     }
    //     catch (Exception ex)
    //     {
    //         Snackbar.Add($"Patch failed: {ex.Message}", Severity.Error);
    //     }
    // }

    private async Task OpenContextMenu(DataGridRowClickEventArgs<CrowdGroupMaster> args)
    {
        _contextRow = args.Item;
        await _contextMenu.OpenMenuAsync(args.MouseEventArgs);
    }

    private void EditFromContext()
    {
        if (_contextRow is not null)
        {
            EditGroup(_contextRow);
        }
    }

    private async Task DeleteFromContext()
    {
        if (_contextRow is not null)
        {
            await DeleteGroup(_contextRow.Id);
        }
    }

    private async Task ShowAudits()
    {
        if (_contextRow is null) return;

        var auditResult = await CloudHistoryService.GetCrowdGroupAudit(_contextRow.Id);

        var parameters = new DialogParameters
        {
            ["Title"] = $"Audit of Crowd Group: {_contextRow.CrwdgroupName}",
            ["AuditRecords"] = auditResult
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<CrowdGroupAuditDialog>("", parameters, options);
        var result = await dialog.Result;
    }

    private void OpenAddDrawer()
    {
        isEdit = false;
        drawerFullscreen = false;
        selectedBusinessFunction = null;

        editingGroup = new CrowdGroupMaster
        {
            DateCreated = DateTime.UtcNow,
            DateModified = DateTime.UtcNow
        };

        drawerOpen = true;
        StateHasChanged();
    }

    private void EditGroup(CrowdGroupMaster group)
    {
        isEdit = true;
        drawerFullscreen = false;

        editingGroup = new CrowdGroupMaster
        {
            Id = group.Id,
            CrwdgroupName = group.CrwdgroupName,
            GroupType = group.GroupType,
            GroupId = group.GroupId,
            Provider = group.Provider,
            Remarks = group.Remarks,
            AllAccountIds = group.AllAccountIds,
            BusinessFunctionId = group.BusinessFunctionId,

            DateCreated = group.DateCreated,
            DateModified = DateTime.UtcNow
        };

        selectedBusinessFunction = businessFunctions
            .FirstOrDefault(x => x.Id == editingGroup.BusinessFunctionId);

        drawerOpen = true;
        StateHasChanged();
    }

    private void CloseDrawer()
    {
        drawerOpen = false;
        drawerFullscreen = false;
        editingGroup = new CrowdGroupMaster();
        selectedBusinessFunction = null;
        StateHasChanged();
    }

    private void ToggleFullscreen()
    {
        drawerFullscreen = !drawerFullscreen;
        StateHasChanged();
    }

    private async Task SaveGroup()
    {
        if (string.IsNullOrWhiteSpace(editingGroup.CrwdgroupName))
        {
            Snackbar.Add("CRWD Group Name is required", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(editingGroup.GroupType))
        {
            Snackbar.Add("Group Type is required", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(editingGroup.GroupId))
        {
            Snackbar.Add("Group ID is required", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(editingGroup.Provider))
        {
            Snackbar.Add("Provider is required", Severity.Warning);
            return;
        }

        if (selectedBusinessFunction is null)
        {
            Snackbar.Add("Business Function is required", Severity.Warning);
            return;
        }

        try
        {
            isSaving = true;
            StateHasChanged();

            // Assign the selected business function ID before saving
            editingGroup.BusinessFunctionId = selectedBusinessFunction.Id;

            if (isEdit)
            {
                await CrowdGroupService.UpdateAsync(editingGroup);
                Snackbar.Add("Crowd group updated successfully", Severity.Success);
            }
            else
            {
                await CrowdGroupService.CreateAsync(editingGroup);
                Snackbar.Add("Crowd group created successfully", Severity.Success);
            }

            await LoadData();
            CloseDrawer();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving group: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteGroup(int id)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Delete Crowd Group",
            "Are you sure you want to delete this crowd group? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await CrowdGroupService.DeleteAsync(id);
                await LoadData();
                Snackbar.Add("Crowd group deleted successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting group: {ex.Message}", Severity.Error);
            }
        }
    }
}