@page "/crowdgroupmaster"

@using CloudAccountsShared.Models
@using CloudAccountsUI.Services.Contracts
@using System.Net.Http.Json
@inject ICrowdGroupMasterService CrowdGroupService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject HttpClient Http

<div class="full-page-container">
    <div class="main-wrapper @(drawerOpen && !drawerFullscreen ? "drawer-open" : "") @(drawerFullscreen ? "fullscreen-active" : "")">
        <div class="pushed-content">
            <div class="header-toolbar">
                <div class="title-section">
                    <div class="cs-title">
                        <MudIcon Icon="@Icons.Material.Filled.Groups" Class="mr-2" Style="color: #00A3FF;" />
                        Crowd Groups Master
                    </div>
                    <div class="cs-subtitle">
                        Manage and monitor all your crowd groups across providers
                    </div>
                </div>
                <div class="actions-section">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenAddDrawer">
                        Add Group
                    </MudButton>
                </div>
            </div>

            <div class="grid-container">
                @if (isLoading)
                {
                    <div style="display: flex; justify-content: center; align-items: center; height: 400px;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                    </div>
                }
                else if (groups.Count == 0)
                {
                    <div style="display: flex; justify-content: center; align-items: center; height: 400px; flex-direction: column;">
                        <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Large" Style="color: #CBD5E1; margin-bottom: 16px;" />
                        <MudText Typo="Typo.h6" Style="color: #5A6A85;">No crowd groups found</MudText>
                        <MudText Typo="Typo.body2" Style="color: #94A3B8; margin-top: 8px;">Click "Add Group" to create your first crowd group</MudText>
                    </div>
                }
                else
                {
                    <MudDataGrid T="CrowdGroupMaster"
                                 @ref="_dataGrid"
                                 Items="@groups"
                                 Dense="true"
                                 Hover="true"
                                 Bordered="true"
                                 Striped="true"
                                 Filterable="true"
                                 FilterMode="DataGridFilterMode.ColumnFilterRow"
                                 FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive"
                                 FixedHeader="true"
                                 @bind-PageSize="PageSize"
                                 RowsPerPageOptions="@PageSizeOptions"
                                 Height="100%"
                                 Width="100%"
                                 RowContextMenuClick="OpenContextMenu">

                        <Columns>
                            <PropertyColumn Property="x => x.CrwdgroupName" Title="CRWD Group Name" Resizable="true" />
                            <PropertyColumn Property="x => x.GroupType" Title="Group Type" Resizable="true" />
                            <PropertyColumn Property="x => x.GroupId" Title="Group ID" Resizable="true" />
                            <PropertyColumn Property="x => x.Provider" Title="Provider" Resizable="true" />
                            <PropertyColumn Property="x => x.BusinessFunctionId" Title="Business Function ID" Resizable="true" />
                            <PropertyColumn Property="x => x.AllAccountIds" Title="All Account IDs" Resizable="true" />

                            <PropertyColumn Property="x => x.UpdatedDate" Title="Updated Date" Resizable="true">
                                <CellTemplate Context="cell">
                                    <span>@(cell.Item.UpdatedDate == default ? "-" : cell.Item.UpdatedDate.ToString("yyyy-MM-dd HH:mm"))</span>
                                </CellTemplate>
                            </PropertyColumn>
                        </Columns>

                        <NoRecordsContent>
                            <MudText Class="pa-4" Style="color: #5A6A85;">No matching records found</MudText>
                        </NoRecordsContent>

                        <PagerContent>
                            <MudDataGridPager T="CrowdGroupMaster" PageSizeOptions="@PageSizeOptions" />
                        </PagerContent>
                    </MudDataGrid>
                }
            </div>
        </div>
    </div>

    <!-- Context Menu -->
    <MudMenu PositionAtCursor="true" @ref="_contextMenu" id="_contextMenu">
        <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => EditFromContext())">
            Edit @_contextRow?.CrwdgroupName
        </MudMenuItem>
        <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="@(() => DeleteFromContext())">
            Delete @_contextRow?.CrwdgroupName
        </MudMenuItem>
    </MudMenu>

    <!-- Drawer for Add/Edit - Splits the page -->
    <div class="drawer-container @(drawerOpen ? "open" : "") @(drawerFullscreen ? "fullscreen" : "")">
        @if (drawerOpen)
        {
            <div class="drawer-content">
                <div class="drawer-header">
                    <div class="drawer-title">@(isEdit ? "Edit Crowd Group" : "Add Crowd Group")</div>
                    <div class="drawer-buttons">
                        <MudIconButton Icon="@(drawerFullscreen? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                                       Size="Size.Medium"
                                       Color="Color.Default"
                                       OnClick="ToggleFullscreen" />
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Size="Size.Medium"
                                       Color="Color.Default"
                                       OnClick="CloseDrawer" />
                    </div>
                </div>

                <div style="flex: 1; overflow-y: auto; padding-right: 8px;">
                    <MudStack Spacing="2">
                        <MudTextField T="string"
                                      Label="CRWD Group Name"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingGroup.CrwdgroupName"
                                      Dense="true"
                                      Required="true" />

                        <MudSelect T="string"
                                   Label="Group Type"
                                   Variant="Variant.Outlined"
                                   @bind-Value="editingGroup.GroupType"
                                   Dense="true"
                                   Required="true">
                            <MudSelectItem Value="@("Host_Group")">Host_Group</MudSelectItem>
                            <MudSelectItem Value="@("Cloud_Group")">Cloud_Group</MudSelectItem>
                        </MudSelect>

                        <MudTextField T="string"
                                      Label="Group ID"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingGroup.GroupId"
                                      Dense="true"
                                      Required="true" />

                        <MudSelect T="string"
                                   Label="Provider"
                                   Variant="Variant.Outlined"
                                   @bind-Value="editingGroup.Provider"
                                   Dense="true"
                                   Required="true">
                            <MudSelectItem Value="@("AWS")">AWS</MudSelectItem>
                            <MudSelectItem Value="@("Azure")">Azure</MudSelectItem>
                            <MudSelectItem Value="@("GCP")">GCP</MudSelectItem>
                        </MudSelect>

                        <!-- Business Function Dropdown -->
                        <MudSelect T="int"
                                   Label="Business Function"
                                   Variant="Variant.Outlined"
                                   @bind-Value="editingGroup.BusinessFunctionId"
                                   Dense="true"
                                   Required="true">
                            @foreach (var bf in businessFunctions)
                            {
                                <MudSelectItem T="int" Value="@bf.Id">@bf.BusinessFunctionName</MudSelectItem>
                            }
                        </MudSelect>

                        <MudTextField T="string"
                                      Label="All Account IDs"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingGroup.AllAccountIds"
                                      Dense="true"
                                      HelperText="Comma-separated account IDs"
                                      Lines="2" />

                        <MudTextField T="string"
                                      Label="Remarks"
                                      Variant="Variant.Outlined"
                                      @bind-Value="editingGroup.Remarks"
                                      Lines="3"
                                      Dense="true" />
                    </MudStack>
                </div>

                <div class="drawer-footer">
                    <MudButton Variant="Variant.Text"
                               OnClick="CloseDrawer"
                               Style="color: #5A6A85;">
                        Cancel
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Style="background: #00A3FF; color: white; font-weight: 600;"
                               OnClick="SaveGroup"
                               Disabled="@isSaving">
                        @if (isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                            <span class="ml-2">Saving...</span>
                        }
                        else
                        {
                            <span>Save</span>
                        }
                    </MudButton>
                </div>
            </div>
        }
    </div>
</div>

<style>
    ::deep .mud-layout {
        padding: 0 !important;
        margin: 0 !important;
    }

    ::deep .mud-main-content {
        padding: 0 !important;
        margin: 0 !important;
    }

    .full-page-container {
        width: 100%;
        height: 100vh;
        padding: 0;
        margin: 0;
        overflow: hidden;
        background: white;
        display: flex;
        flex-direction: column;
    }

    .main-wrapper {
        flex: 1;
        display: flex;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .pushed-content {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .header-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid #E2E8F0;
        flex-shrink: 0;
        background: white;
    }

    .title-section {
        flex: 1;
    }

    .cs-title {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
        font-size: 20px;
        font-weight: 600;
        color: #1A1D2E;
        letter-spacing: -0.3px;
    }

    .cs-subtitle {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
        font-size: 13px;
        color: #5A6A85;
        margin-top: 4px;
    }

    .actions-section {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .grid-container {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        min-height: 0;
        position: relative;
        padding: 20px;
    }

    .drawer-container {
        width: 0;
        flex-shrink: 0;
        overflow: hidden;
        transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: white;
        border-left: 1px solid #E2E8F0;
        height: calc(100vh - 63px);
        position: fixed;
        right: 0;
        top: 63px;
        z-index: 1000;
        display: flex;
        flex-direction: column;
    }

    .drawer-content {
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        padding: 20px;
    }

        .drawer-container.open {
            width: 50%;
            min-width: 500px;
            max-width: 700px;
        }

    .main-wrapper.drawer-open {
        margin-right: 50%;
        min-width: calc(100% - 700px);
        max-width: calc(100% - 500px);
    }

    .drawer-container.fullscreen {
        width: 100% !important;
        min-width: 100%;
