    }

    private void AddCurrentSpoc(FocusEventArgs _)
    {
        if (string.IsNullOrWhiteSpace(spocInput))
            return;

        var value = spocInput.Trim();

        if (!SelectedSpocs.Any(x => x.Equals(value, StringComparison.OrdinalIgnoreCase)))
        {
            SelectedSpocs.Add(value);
        }

        editingItem.BusinessFunctionSpoc = string.Join(";", SelectedSpocs);

        spocInput = string.Empty;
    }

    private void RemoveSpoc(string spoc)
    {
        SelectedSpocs.Remove(spoc);
        editingItem.BusinessFunctionSpoc = string.Join(";", SelectedSpocs);
        StateHasChanged();
    }

    private void AddTag()
    {
        BusinessTags.Add(new BusinessTagItem());
    }

    private void RemoveTag(BusinessTagItem tag)
    {
        BusinessTags.Remove(tag);
    }

    private async Task OpenCreateDrawer()
    {
        drawerFullscreen = false;
        drawerOpen = false;
        await Task.Delay(50);

        isCreate = true;
        editingItem = new BusinessFunction();
        SelectedSpocs = new List<string>();
        BusinessTags = new List<BusinessTagItem>();
        BusinessTags.Add(new BusinessTagItem());
        spocInput = string.Empty;
        drawerOpen = true;
        StateHasChanged();
    }

    private async Task OpenEditDrawer(BusinessFunction item)
    {
        drawerFullscreen = false;
        drawerOpen = false;
        await Task.Delay(50);

        isCreate = false;
        editingItem = new BusinessFunction
        {
            Id = item.Id,
            BusinessFunctionName = item.BusinessFunctionName,
            BusinessFunctionLtMember = item.BusinessFunctionLtMember,
            BusinessFunctionOwner = item.BusinessFunctionOwner,
            BusinessFunctionSpoc = item.BusinessFunctionSpoc,
            BusinessFunctionGroupDl = item.BusinessFunctionGroupDl,
            BusinessTagValue = item.BusinessTagValue,
            Remarks = item.Remarks
        };

        SelectedSpocs = string.IsNullOrWhiteSpace(editingItem.BusinessFunctionSpoc)
            ? new List<string>()
            : editingItem.BusinessFunctionSpoc
                .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();

        BusinessTags = new List<BusinessTagItem>();
        if (!string.IsNullOrWhiteSpace(editingItem.BusinessTagValue))
        {
            BusinessTags = editingItem.BusinessTagValue
                .Split(';', StringSplitOptions.RemoveEmptyEntries)
                .Select(x =>
                {
                    var parts = x.Split('=', 2);
                    return new BusinessTagItem
                    {
                        Name = parts[0],
                        Value = parts.Length > 1 ? parts[1] : ""
                    };
                })
                .ToList();
        }

        if (!BusinessTags.Any())
        {
            BusinessTags.Add(new BusinessTagItem());
        }

        spocInput = string.Empty;
        drawerOpen = true;
        StateHasChanged();
    }

    private void CloseDrawer()
    {
        drawerOpen = false;
        drawerFullscreen = false;
        editingItem = new BusinessFunction();
        SelectedSpocs = new List<string>();
        BusinessTags = new List<BusinessTagItem>();
        spocInput = string.Empty;
        StateHasChanged();
    }

    private async Task Save()
    {
        editingItem.BusinessTagValue = string.Join(";",
            BusinessTags
                .Where(x => !string.IsNullOrWhiteSpace(x.Name))
                .Select(x => $"{x.Name}={x.Value}"));

        HttpResponseMessage response;

        if (isCreate)
        {
            response = await Http.PostAsJsonAsync(ApiBase, editingItem);
        }
        else
        {
            response = await Http.PutAsJsonAsync($"{ApiBase}/{editingItem.Id}", editingItem);
        }

        if (response.IsSuccessStatusCode)
        {
            await LoadData();
            CloseDrawer();
            Snackbar.Add(isCreate ? "Business function added successfully" : "Business function updated successfully", Severity.Success);
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            Snackbar.Add($"Save failed: {error}", Severity.Error);
        }
    }
}