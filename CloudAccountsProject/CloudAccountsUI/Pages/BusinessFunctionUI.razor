@code {
    // public class BusinessTagItem
    // {
    //     public string? Name { get; set; }
    //     public string? Value { get; set; }
    // }

    public class ColumnDefinition
    {
        public string Title { get; set; } = string.Empty;
        public bool IsVisible { get; set; } = true;
        public int Order { get; set; }
    }

    private MudDataGrid<BusinessFunctionMaster> _dataGrid = null!;
    private MudMenu _contextMenu = null!;
    private BusinessFunctionMaster? _contextRow;
    private bool isLoading = true;
    private int PageSize = 10;
    private int[] PageSizeOptions = new[] { 10, 25, 50, 100 };
    private bool drawerFullscreen = false;
    [CascadingParameter]
    public MainLayout? Layout { get; set; }
    private bool showColumnDialog = false;
    private List<string> viewableColumns = new();
    private List<string> editableColumns = new();

    private bool CanView(string columnName)
        => viewableColumns.Contains(columnName) || editableColumns.Contains(columnName);

    private bool CanEdit(string columnName)
        => editableColumns.Contains(columnName);

