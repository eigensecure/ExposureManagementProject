    private Task<IEnumerable<string>> SearchSpocs(string value, CancellationToken token)
    {
        var allSpocs = businessFunctions
            .Where(x => !string.IsNullOrWhiteSpace(x.BusinessFunctionSpoc))
            .SelectMany(x => x.BusinessFunctionSpoc!
                .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            .Distinct()
            .Where(x => !SelectedSpocs.Contains(x));

        if (!string.IsNullOrWhiteSpace(value))
        {
            allSpocs = allSpocs.Where(x =>
                x.Contains(value, StringComparison.OrdinalIgnoreCase));
        }

        return Task.FromResult(allSpocs);
    }

    private void HandleSpocKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddCurrentSpoc(new FocusEventArgs());
        }
    }

    private Task<IEnumerable<string>> SearchGroupDl(string value, CancellationToken token)
    {
        IEnumerable<string> result = businessFunctions
            .Where(x => !string.IsNullOrWhiteSpace(x.BusinessFunctionGroupDl))
            .Select(x => x.BusinessFunctionGroupDl!)
            .Distinct();

        if (!string.IsNullOrWhiteSpace(value))
            result = result.Where(x => x.Contains(value, StringComparison.OrdinalIgnoreCase));

        return Task.FromResult(result);
    }

    private void AddCurrentSpoc(FocusEventArgs _)
    {
        if (string.IsNullOrWhiteSpace(spocInput))
            return;

        var value = spocInput.Trim();

        if (!SelectedSpocs.Any(x => x.Equals(value, StringComparison.OrdinalIgnoreCase)))
        {
            SelectedSpocs.Add(value);
        }

        editingItem.BusinessFunctionSpoc = string.Join(";", SelectedSpocs);

        spocInput = string.Empty;
    }

    private void RemoveSpoc(string spoc)
    {
        SelectedSpocs.Remove(spoc);
        editingItem.BusinessFunctionSpoc = string.Join(";", SelectedSpocs);
        StateHasChanged();
    }

