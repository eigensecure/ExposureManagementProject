    private async Task OpenEditDrawer(BusinessFunctionMaster item)
    {
        drawerFullscreen = false;
        drawerOpen = false;
        await Task.Delay(50);

        isCreate = false;
        editingItem = new BusinessFunctionMaster
        {
            Id = item.Id,
            BusinessFunctionName = item.BusinessFunctionName,
            BusinessFunctionLtMember = item.BusinessFunctionLtMember,
            BusinessFunctionOwner = item.BusinessFunctionOwner,
            BusinessFunctionSpoc = item.BusinessFunctionSpoc,
            BusinessFunctionGroupDl = item.BusinessFunctionGroupDl,
            // BusinessTags = item.BusinessTags?.ToList() ?? new List<BusinessTag>(),
            Remarks = item.Remarks
        };

        SelectedSpocs = string.IsNullOrWhiteSpace(editingItem.BusinessFunctionSpoc)
            ? new List<string>()
            : editingItem.BusinessFunctionSpoc
                .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();

