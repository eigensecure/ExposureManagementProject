@page "/businessfunction"
@using CloudAccountsShared.Models
@using CloudAccountsUI.Dialogs.AuditDialogs
@using CloudAccountsUI.Services.Contracts
@using MudBlazor
@using CloudAccountsShared.Configuration.Services.Contracts
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ICloudHistoryService cloudhistoryservice
@inject IBusinessFunctionService BusinessFunctionService
@inject ITableConfigService TableConfigService
@inherits LayoutComponentBase

<div class="full-page-container">
    
    <div class="main-wrapper @(drawerOpen && !drawerFullscreen ? "drawer-open" : "") @(drawerFullscreen ? "fullscreen-active" : "")">
       
        <div class="pushed-content">

            @* DataGrid *@
            <div class="grid-container pa-5">
                <div class="data-grid-wrapper">
                    <MudDataGrid T="BusinessFunctionMaster"
                                 @ref="_dataGrid"
                                 Items="@businessFunctions"
                                 Dense="true"
                                 Hover="true"
                                 Bordered="true"
                                 Striped="true"
                                 Filterable="true"
                                 FilterMode="DataGridFilterMode.ColumnFilterRow"
                                 FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive"
                                 ShowColumnOptions="true"
                                 FixedHeader="true"
                                 FixedFooter="true"
                                 @bind-PageSize="PageSize"
                                 RowsPerPageOptions="@PageSizeOptions"
                                 Width="100%"
                                 Loading="@isLoading"
                                 ColumnResizeMode="ResizeMode.Container"
                                 DragDropColumnReordering="true"
                                 ColumnsPanelReordering="true"
                                 ShowMenuIcon="true"
                                 RowContextMenuClick="OpenContextMenu">

                        <ToolBarContent>
                            <div class="d-flex flex-column">
                                <MudText Typo="Typo.h6" Class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Groups"
                                             Class="mr-2"
                                             Style="color: #00A3FF;" />
                                    Business Function Management
                                </MudText>

                                <MudText Typo="Typo.body2" Class="text-secondary">
                                    Manage business functions, owners, and SPOC information
                                </MudText>
                            </div>

                            <MudSpacer />

                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="OpenCreateDrawer">
                                Add Business Function
                            </MudButton>
                        </ToolBarContent>

                        <Columns>
                            @if (viewableColumns.Contains(nameof(BusinessFunctionMaster.BusinessFunctionName)))
                            {
                                <PropertyColumn Property="x => x.BusinessFunctionName"
                                                Title="Business Function Name"
                                                Width="240px"
                                                Resizable="true"
                                                Hideable="true"
                                                StickyLeft="true"
                                                HeaderStyle="white-space: nowrap; position: sticky; left: 0; background: #F8F9FC; z-index: 10;"
                                                CellStyle="position: sticky; left: 0; background: white; z-index: 5;">

                                    <CellTemplate Context="context">
                                        <div class="business-function-name-cell">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                           Size="Size.Small"
                                                           Class="edit-button-inline"
                                                           OnClick="() => OpenEditDrawer(context.Item)"
                                                           Style="color: #00A3FF; margin-right: 8px;" />

                                            <MudTooltip Text="@context.Item.BusinessFunctionName" Placement="Placement.Top">
                                                <span class="truncate-text">@context.Item.BusinessFunctionName</span>
                                            </MudTooltip>
                                        </div>
                                    </CellTemplate>
                                </PropertyColumn>
                            }

                            @if (viewableColumns.Contains(nameof(BusinessFunctionMaster.BusinessFunctionLtMember)))
                            {
                                <PropertyColumn Property="x => x.BusinessFunctionLtMember"
                                                Title="LT Member"
                                                Width="180px"
                                                Resizable="true"
                                                Hideable="true"
                                                HeaderStyle="white-space: nowrap;"
                                                CellStyle="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" />
                            }

                            @if (viewableColumns.Contains(nameof(BusinessFunctionMaster.BusinessFunctionOwner)))
                            {
                                <PropertyColumn Property="x => x.BusinessFunctionOwner"
                                                Title="Owner"
                                                Width="180px"
                                                Resizable="true"
                                                Hideable="true"
                                                HeaderStyle="white-space: nowrap;"
                                                CellStyle="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" />
                            }

                            @if (viewableColumns.Contains(nameof(BusinessFunctionMaster.BusinessFunctionSpoc)))
                            {
                                <PropertyColumn Property="x => x.BusinessFunctionSpoc"
                                                Title="SPOC"
                                                Width="220px"
                                                Resizable="true"
                                                Hideable="true"
                                                HeaderStyle="white-space: nowrap;"
                                                CellStyle="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" />
                            }

                            @if (viewableColumns.Contains(nameof(BusinessFunctionMaster.BusinessFunctionGroupDl)))
                            {
                                <PropertyColumn Property="x => x.BusinessFunctionGroupDl"
                                                Title="Group DL"
                                                Width="240px"
                                                Resizable="true"
                                                Hideable="true"
                                                HeaderStyle="white-space: nowrap;"
                                                CellStyle="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" />
                            }

                            @if (viewableColumns.Contains(nameof(BusinessFunctionMaster.BusinessTagValue)))
                            {
                                <PropertyColumn Property="x => x.BusinessTagValue"
                                                Title="Business Tag"
                                                Width="260px"
                                                Resizable="true"
                                                Hideable="true"
                                                HeaderStyle="white-space: nowrap;"
                                                CellStyle="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" />
                            }

                            @if (viewableColumns.Contains(nameof(BusinessFunctionMaster.Remarks)))
                            {
                                <PropertyColumn Property="x => x.Remarks"
                                                Title="Remarks"
                                                Width="260px"
                                                Resizable="true"
                                                Hideable="true"
                                                HeaderStyle="white-space: nowrap;"
                                                CellStyle="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" />
                            }
                        </Columns>

                        <NoRecordsContent>
                            <MudText Class="pa-4" Style="color: #5A6A85;">
                                No business Functions found
                                Click "Add Business Function" to create your Business Function
                            </MudText>
                        </NoRecordsContent>

                        <PagerContent>
                            <MudDataGridPager T="BusinessFunctionMaster"
                                              PageSizeOptions="@PageSizeOptions" />
                        </PagerContent>
                    </MudDataGrid>
                </div>
            </div>
        </div>
    </div>
</div>

    
<div class="drawer-container @(drawerOpen ? "open" : "") @(drawerFullscreen ? "fullscreen" : "")">
    @if (drawerOpen)
    {
        <div class="drawer-content">
            <div class="drawer-header">
                <div class="drawer-title">@(isCreate ? "Add Business Function" : "Edit Business Function")</div>
                <div class="drawer-buttons">
                    <MudIconButton Icon="@(drawerFullscreen ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                                   Size="Size.Medium"
                                   Color="Color.Default"
                                   OnClick="ToggleFullscreen" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Medium"
                                   Color="Color.Default"
                                   OnClick="CloseDrawer" />
                </div>
            </div>

            <div style="flex: 1; overflow-y: auto; padding-right: 8px;">
                <MudStack Spacing="2">

                    @if (CanView(nameof(BusinessFunctionMaster.BusinessFunctionName)))
                    {
                        <MudAutocomplete T="string"
                                         @key="@("bfname")"
                                         Label="Business Function Name"
                                         Variant="Variant.Outlined"
                                         @bind-Value="editingItem.BusinessFunctionName"
                                         SearchFunc="SearchBusinessFunctionNames"
                                         Dense="true"
                                         Clearable="true"
                                         ResetValueOnEmptyText="false"
                                         Strict="false"
                                         CoerceText="false"
                                         CoerceValue="true"
                                         Required="true"
                                         Disabled="@(!CanEdit(nameof(BusinessFunctionMaster.BusinessFunctionName)))" />
                    }

                    @if (CanView(nameof(BusinessFunctionMaster.BusinessFunctionLtMember)))
                    {
                        <MudAutocomplete T="string"
                                         @key="@("ltmember")"
                                         Label="LT Member"
                                         Variant="Variant.Outlined"
                                         @bind-Value="editingItem.BusinessFunctionLtMember"
                                         SearchFunc="SearchLtMembers"
                                         Dense="true"
                                         Clearable="true"
                                         ResetValueOnEmptyText="false"
                                         Strict="false"
                                         CoerceText="false"
                                         CoerceValue="true"
                                         Required="true"
                                         Disabled="@(!CanEdit(nameof(BusinessFunctionMaster.BusinessFunctionLtMember)))" />
                    }

                    @if (CanView(nameof(BusinessFunctionMaster.BusinessFunctionOwner)))
                    {
                        <MudAutocomplete T="string"
                                         @key="@("owner")"
                                         Label="Owner"
                                         Variant="Variant.Outlined"
                                         @bind-Value="editingItem.BusinessFunctionOwner"
                                         SearchFunc="SearchOwners"
                                         Dense="true"
                                         Clearable="true"
                                         ResetValueOnEmptyText="false"
                                         Strict="false"
                                         CoerceText="false"
                                         CoerceValue="true"
                                         Required="true"
                                         Disabled="@(!CanEdit(nameof(BusinessFunctionMaster.BusinessFunctionOwner)))" />
                    }

                    @if (CanView(nameof(BusinessFunctionMaster.BusinessFunctionSpoc)))
                    {
                        <MudAutocomplete T="string"
                                         Label="Add SPOC"
                                         SearchFunc="SearchSpocs"
                                         @bind-Value="spocInput"
                                         Variant="Variant.Outlined"
                                         Dense="true"
                                         Clearable="true"
                                         Strict="false"
                                         CoerceText="false"
                                         CoerceValue="true"
                                         ResetValueOnEmptyText="false"
                                         OnBlur="AddCurrentSpoc"
                                         OnKeyDown="HandleSpocKeyDown"
                                         Disabled="@(!CanEdit(nameof(BusinessFunctionMaster.BusinessFunctionSpoc)))" />

                        <MudChipSet T="string" Class="mb-3">
                            @foreach (var spoc in SelectedSpocs)
                            {
                                <MudChip T="string"
                                         Text="@spoc"
                                         Closeable="@CanEdit(nameof(BusinessFunctionMaster.BusinessFunctionSpoc))"
                                         OnClose="@(() => RemoveSpoc(spoc))" />
                            }
                        </MudChipSet>
                    }

                    @if (CanView(nameof(BusinessFunctionMaster.BusinessFunctionGroupDl)))
                    {
                        <MudAutocomplete T="string"
                                         Label="Group DL"
                                         Variant="Variant.Outlined"
                                         @bind-Value="editingItem.BusinessFunctionGroupDl"
                                         SearchFunc="SearchGroupDl"
                                         Dense="true"
                                         Clearable="true"
                                         ResetValueOnEmptyText="false"
                                         Strict="false"
                                         CoerceText="false"
                                         CoerceValue="true"
                                         Disabled="@(!CanEdit(nameof(BusinessFunctionMaster.BusinessFunctionGroupDl)))" />
                    }

                    @if (CanView(nameof(BusinessFunctionMaster.BusinessTagValue)))
                    {
                        @* <MudText Typo="Typo.subtitle2"
                                 Class="mb-2 mt-2"
                                 Style="color: #1A1D2E; font-size: 13px; font-weight: 600;">
                            Business Tag
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Class="mb-3"
                                 Style="color: #5A6A85; font-size: 12px;">
                            Tags are name/value pairs that enable you to categorize resources and view consolidated billing
                        </MudText> *@
                    }

                    <MudAutocomplete T="string"
                                     Label="Business Tag"
                                     Variant="Variant.Outlined"
                                     @bind-Value="editingItem.BusinessTagValue"
                                     SearchFunc="SearchBusinessTags"
                                     Dense="true"
                                     Clearable="true"
                                     ResetValueOnEmptyText="false"
                                     Strict="false"
                                     CoerceText="false"
                                     CoerceValue="true"
                                     Disabled="@(!CanEdit(nameof(BusinessFunctionMaster.BusinessTagValue)))" />

                    @if (CanView(nameof(BusinessFunctionMaster.Remarks)))
                    {
                        <MudTextField T="string"
                                      @bind-Value="editingItem.Remarks"
                                      Label="Remarks"
                                      Variant="Variant.Outlined"
                                      Lines="3"
                                      Disabled="@(!CanEdit(nameof(BusinessFunctionMaster.Remarks)))" />
                    }
                </MudStack>
            </div>

            <div class="drawer-footer">
                <MudButton Variant="Variant.Text"
                           OnClick="CloseDrawer"
                           Style="color: #5A6A85;">
                    Cancel
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Style="background: #00A3FF; color: white; font-weight: 600;"
                           OnClick="Save">
                    Save
                </MudButton>
            </div>
        </div>
    }
</div>

@if (showColumnDialog)
{
    <div class="overlay" @onclick="CloseColumnSelector"></div>
    <div class="column-selector-dialog">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <MudText Typo="Typo.h6" Style="color: #1A1D2E; font-weight: 600;">Select Columns</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CloseColumnSelector" Style="color: #5A6A85;" />
        </div>
        <MudDivider Class="mb-3" />
        @foreach (var column in AvailableColumns.Where(c => c.Title != "Actions"))
        {
            <MudSwitch @bind-Value="column.IsVisible" Label="@column.Title" Size="Size.Small" Class="mb-2" Color="Color.Primary" />
        }
        <MudDivider Class="mt-2 mb-3" />
        <div style="display: flex; justify-content: flex-end; gap: 8px;">
            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ResetColumns">Reset</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="ApplyColumnVisibility">Apply</MudButton>
        </div>
    </div>
}

<MudMenu PositionAtCursor="true" @ref="_contextMenu" id="_contextMenu">
    <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => EditFromContext())">
        Edit @_contextRow?.BusinessFunctionName
    </MudMenuItem>
    <MudMenuItem Icon="@Icons.Material.Filled.Info" OnClick="@ShowAudits">
        View Audits for @_contextRow?.BusinessFunctionName
    </MudMenuItem>
    <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="@ConfirmDelete">
        Delete
    </MudMenuItem>
</MudMenu>

