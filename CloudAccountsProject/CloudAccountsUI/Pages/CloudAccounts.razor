@page "/cloudaccounts"
@using System.Net.Http.Json
@using CloudAccountsUI.Models
@using MudBlazor
@inject HttpClient Http

<MudPaper Class="pa-4">

    <MudText Typo="Typo.h5" Class="mb-4">Cloud Accounts</MudText>

    @if (isLoading)
    {
        <MudPaper Class="pa-6 d-flex flex-column align-center justify-center"
                  Elevation="0"
                  Style="height:650px;">

            <MudProgressCircular Indeterminate="true"
                                 Color="Color.Primary"
                                 Size="Size.Large" />

            <MudText Typo="Typo.body1" Class="mt-4">
                Loading Cloud Accounts...
            </MudText>

        </MudPaper>
    }
    else
    {
        <MudDataGrid T="CloudAccount"
                     Items="@Accounts"
                     Dense="true"
                     Hover="true"
                     Bordered="true"
                     Striped="true"
                     Filterable="true"
                     FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive"
                     ShowColumnOptions="false"
                     FixedHeader="true"
                     Height="650px"
                     RowsPerPage="10"
                     Elevation="0"
                     Class="clean-grid">

            <Columns>

                <PropertyColumn Property="x => x.Provider"
                                Title="Provider" />

                <PropertyColumn Property="x => x.CloudAccountId"
                                Title="Cloud Account ID"
                                StickyLeft="true" />

                <PropertyColumn Property="x => x.CloudName"
                                Title="Cloud Name" />

                <PropertyColumn Property="x => x.CloudOrgId"
                                Title="Cloud Org ID" />

                <PropertyColumn Property="x => x.CloudRootAccountId"
                                Title="Cloud Root Account ID" />

                <PropertyColumn Property="x => x.RegistrationType"
                                Title="Registration Type" />

                <PropertyColumn Property="x => x.DeploymentMethod"
                                Title="Deployment Method" />

                <PropertyColumn Property="x => x.Iomstatus"
                                Title="IOM Status" />

                <PropertyColumn Property="x => x.RealTimeVisibilityAndDetectionStatus"
                                Title="RTVD Status" />

                <PropertyColumn Property="x => x.OneClickSensorStatus"
                                Title="1-Click Sensor Status" />

                <PropertyColumn Property="x => x.IdentityProtectionStatus"
                                Title="Identity Protection Status" />

                <PropertyColumn Property="x => x.Dspmstatus"
                                Title="DSPM Status" />

                <PropertyColumn Property="x => x.VulnerabilityScanningStatus"
                                Title="Vulnerability Scanning Status" />

                <PropertyColumn Property="x => x.DateCreated"
                                Title="Date Created">
                    <CellTemplate>
                        @context.Item.DateCreated.ToString("yyyy-MM-dd HH:mm")
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.DateModified"
                                Title="Date Modified">
                    <CellTemplate>
                        @context.Item.DateModified.ToString("yyyy-MM-dd HH:mm")
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn Title="Actions" StickyRight="true">
                    <CellTemplate>
                        <MudButton Variant="Variant.Filled"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="@(() => OpenDrawer(context.Item))">
                            Edit
                        </MudButton>
                    </CellTemplate>
                </TemplateColumn>

            </Columns>

            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="pa-4">
                    No matching records found.
                </MudText>
            </NoRecordsContent>

            <PagerContent>
                <div class="grid-footer">
                    <MudDataGridPager T="CloudAccount" />
                </div>
            </PagerContent>

        </MudDataGrid>
    }

</MudPaper>

<MudDrawer @bind-Open="drawerOpen"
           Anchor="Anchor.Right"
           Variant="DrawerVariant.Temporary"
           Elevation="12"
           Width="750px"
           Class="pa-0">

    @if (editingAccount is not null)
    {
        <MudPaper Class="pa-4" Style="height:100%;overflow-y:auto;">

            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
                <MudText Typo="Typo.h6">Edit Cloud Account</MudText>

                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               OnClick="CloseDrawer" />
            </div>

            <MudText Typo="Typo.subtitle1" Class="mb-3">Cloud Details</MudText>

            <MudTextField T="string"
                          Label="Cloud Name"
                          Variant="Variant.Outlined"
                          Class="mb-3"
                          @bind-Value="editingAccount.CloudName" />

            <MudTextField T="string"
                          Label="Cloud Org ID"
                          Variant="Variant.Outlined"
                          Class="mb-3"
                          @bind-Value="editingAccount.CloudOrgId" />

            <MudTextField T="string"
                          Label="IOM Status"
                          Variant="Variant.Outlined"
                          Class="mb-3"
                          @bind-Value="editingAccount.Iomstatus" />

            <MudTextField T="string"
                          Label="RTVD Status"
                          Variant="Variant.Outlined"
                          Class="mb-3"
                          @bind-Value="editingAccount.RealTimeVisibilityAndDetectionStatus" />

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.subtitle1" Class="mb-3">Business Function</MudText>

            <MudAutocomplete T="string"
                             Label="Business Function Name"
                             Variant="Variant.Outlined"
                             Class="mb-3"
                             Value="@editingAccount.BusinessFunctionId"
                             ValueChanged="OnBusinessFunctionChanged"
                             SearchFunc="SearchBusinessFunctions"
                             Clearable="true"
                             ResetValueOnEmptyText="true"
                             CoerceText="true"
                             Dense="true" />

            <MudTextField T="string"
                          Label="Owner"
                          Value="@editingAccount.BusinessFunctionOwner"
                          Disabled="true"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudTextField T="string"
                          Label="LT Member"
                          Value="@editingAccount.BusinessFunctionLtMember"
                          Disabled="true"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudTextField T="string"
                          Label="SPOC"
                          Value="@editingAccount.BusinessFunctionSpoc"
                          Disabled="true"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.subtitle1" Class="mb-3">Manual Details</MudText>

            <MudSelect T="string"
                       Label="Account Type"
                       Variant="Variant.Outlined"
                       Class="mb-3"
                       @bind-Value="editingAccount.AccountType">

                <MudSelectItem Value='"Hybrid"'>Hybrid</MudSelectItem>
                <MudSelectItem Value='"Managed"'>Managed</MudSelectItem>
                <MudSelectItem Value='"Self-Managed"'>Self-Managed</MudSelectItem>
                <MudSelectItem Value='"Sandbox"'>Sandbox</MudSelectItem>
                <MudSelectItem Value='"SingleAccount"'>SingleAccount</MudSelectItem>
            </MudSelect>

            <MudSelect T="string"
                       Label="Overall Status"
                       Variant="Variant.Outlined"
                       Class="mb-3"
                       @bind-Value="editingAccount.OverallStatus">

                <MudSelectItem Value='"Active"'>Active</MudSelectItem>
                <MudSelectItem Value='"Deleted"'>Deleted</MudSelectItem>
                <MudSelectItem Value='"Disabled"'>Disabled</MudSelectItem>
            </MudSelect>

            <MudTextField T="string"
                          Label="Cloud Tag Email"
                          Variant="Variant.Outlined"
                          Class="mb-3"
                          @bind-Value="editingAccount.CloudTagEmail" />

            <MudTextField T="string"
                          Label="Remarks"
                          Variant="Variant.Outlined"
                          Lines="4"
                          Class="mb-3"
                          @bind-Value="editingAccount.Remarks" />

            <MudStack Row="true"
                      Spacing="2"
                      Class="mt-6">

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SaveEdit">
                    Save
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           OnClick="CloseDrawer">
                    Cancel
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudDrawer>

<style>
    .clean-grid .mud-table-container {
        overflow-x: auto;
        overflow-y: auto;
    }

    .clean-grid .mud-table-pagination {
        border-top: 1px solid rgba(0,0,0,0.08);
        background: white;
        position: sticky;
        bottom: 0;
        z-index: 2;
        min-height: 56px;
    }

    .grid-footer {
        padding: 0 8px;
        background: white;
    }

    .mud-drawer {
        overflow: hidden !important;
    }
</style>

@code {
    private bool isLoading = true;

    private List<CloudAccount> Accounts = new();

    private CloudAccountEditModel? editingAccount;

    private bool drawerOpen;

    private const string ApiBase = "api/CloudAccounts";

    private List<BusinessFunctionLookup> BusinessFunctions = new()
    {
        new()
        {
            BusinessFunctionName = "1234",
            Owner = "Tony",
            LtMember = "Steve",
            Spoc = "Odinson"
        },
        new()
        {
            BusinessFunctionName = "5678",
            Owner = "Billy",
            LtMember = "hugie",
            Spoc = "Frenchie"
        },
        new()
        {
            BusinessFunctionName = "9012",
            Owner = "Wayne",
            LtMember = "Clark",
            Spoc = "Diana"
        }
    };

    protected override async Task OnInitializedAsync()
{
    try
    {
        isLoading = true;

        Accounts = await Http.GetFromJsonAsync<List<CloudAccount>>(ApiBase) ?? new();
    }
    finally
    {
        isLoading = false;
    }
}

    private Task<IEnumerable<string>> SearchBusinessFunctions(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult(
                BusinessFunctions.Select(x => x.BusinessFunctionName).AsEnumerable());
        }

        var result = BusinessFunctions
            .Where(x => x.BusinessFunctionName.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(x => x.BusinessFunctionName);

        return Task.FromResult(result);
    }

    private void OnBusinessFunctionChanged(string value)
    {
        if (editingAccount is null)
            return;

        editingAccount.BusinessFunctionId = value;

        var selected = BusinessFunctions
            .FirstOrDefault(x => x.BusinessFunctionName == value);

        if (selected is not null)
        {
            editingAccount.BusinessFunctionOwner = selected.Owner;
            editingAccount.BusinessFunctionLtMember = selected.LtMember;
            editingAccount.BusinessFunctionSpoc = selected.Spoc;
        }
        else
        {
            editingAccount.BusinessFunctionOwner = string.Empty;
            editingAccount.BusinessFunctionLtMember = string.Empty;
            editingAccount.BusinessFunctionSpoc = string.Empty;
        }

        StateHasChanged();
    }

    private void OpenDrawer(CloudAccount account)
    {
        editingAccount = new CloudAccountEditModel
        {
            Id = account.Id,
            CloudName = account.CloudName,
            CloudOrgId = account.CloudOrgId,
            Iomstatus = account.Iomstatus,
            RealTimeVisibilityAndDetectionStatus = account.RealTimeVisibilityAndDetectionStatus,

            BusinessFunctionId = account.CloudAccountManualDetail?.BusinessFunctionId,
            AccountType = account.CloudAccountManualDetail?.AccountType,
            OverallStatus = account.CloudAccountManualDetail?.OverallStatus,
            Remarks = account.CloudAccountManualDetail?.Remarks,
            CloudTagEmail = account.CloudAccountManualDetail?.CloudTagEmail
        };

        if (!string.IsNullOrWhiteSpace(editingAccount.BusinessFunctionId))
        {
            OnBusinessFunctionChanged(editingAccount.BusinessFunctionId);
        }

        drawerOpen = false;
        StateHasChanged();

        drawerOpen = true;
    }

    private void CloseDrawer()
    {
        drawerOpen = false;
        editingAccount = null;
    }

    private async Task SaveEdit()
{
    if (editingAccount is null)
        return;

    var existing = Accounts.FirstOrDefault(x => x.Id == editingAccount.Id);

    if (existing is null)
        return;

    existing.CloudName = editingAccount.CloudName;
    existing.CloudOrgId = editingAccount.CloudOrgId;
    existing.Iomstatus = editingAccount.Iomstatus;
    existing.RealTimeVisibilityAndDetectionStatus =
        editingAccount.RealTimeVisibilityAndDetectionStatus;

    existing.DateModified = DateTime.UtcNow;

    existing.CloudAccountManualDetail ??= new CloudAccountManualDetail();

    existing.CloudAccountManualDetail.CloudAccountId = existing.Id;
    existing.CloudAccountManualDetail.BusinessFunctionId = editingAccount.BusinessFunctionId;
    existing.CloudAccountManualDetail.AccountType = editingAccount.AccountType;
    existing.CloudAccountManualDetail.OverallStatus = editingAccount.OverallStatus;
    existing.CloudAccountManualDetail.Remarks = editingAccount.Remarks;
    existing.CloudAccountManualDetail.CloudTagEmail = editingAccount.CloudTagEmail;

    var response = await Http.PutAsJsonAsync($"{ApiBase}/{existing.Id}", existing);

    if (response.IsSuccessStatusCode)
    {
        Accounts = await Http.GetFromJsonAsync<List<CloudAccount>>(ApiBase) ?? new();
        CloseDrawer();
    }
    else
    {
        var error = await response.Content.ReadAsStringAsync();
        Console.WriteLine($"Save failed: {error}");
    }
}
}