@page "/cloudaccounts"
@using System.Net.Http.Json
@using CloudAccountsShared.Models
@using CloudAccountsShared.Models.DTOs
@using CloudAccountsUI.Services.Contracts
@using CloudAccountsUI.Dialog
@using MudBlazor
@using MudBlazor.Extensions
@using MudBlazor.Extensions.Options
@inject HttpClient Http
@inject IDialogService DialogService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject ICloudHistoryService cloudhistoryservice

<style>
    .mud-table-pagination {
        display: flex !important;
        justify-content: flex-end;
        align-items: center;
        width: 100%;
        padding: 8px 16px;
    }

    .mud-table-container {
        max-height: calc(100vh - 280px) !important;
        overflow: auto !important;
        position: relative !important;
    }

    .mud-table {
        width: 100%;
    }

        .mud-table table {
            border-collapse: collapse;
            width: 100%;
        }

    .mud-table-head {
        position: sticky !important;
        top: 0 !important;
        z-index: 90 !important;
        background: #f5f5f5 !important;
    }

        .mud-table-head .mud-table-cell {
            font-weight: bold !important;
            white-space: nowrap !important;
            background: #f5f5f5 !important;
            color: #333 !important;
        }

    .mud-data-grid-filter-row .mud-table-cell.mud-table-cell-sticky-left {
        top: 48px !important;
        z-index: 86 !important;
    }

    .mud-table-head .mud-table-cell.mud-table-cell-sticky-left {
        top: 0 !important;
        z-index: 91 !important;
        background: #f5f5f5 !important;
    }

    .mud-table-body .mud-table-cell.mud-table-cell-sticky-left {
        z-index: 75 !important;
        background-color: white !important;
    }

    .cell-content {
        width: 100%;
        white-space: normal;
        word-break: break-word;
        padding: 4px;
    }

    .truncate-text {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
        display: block;
    }

    .main-layout {
        display: flex;
        gap: 16px;
        flex: 1;
        min-height: 0;
    }

    .grid-container {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .drawer-container {
        width: 500px;
        flex-shrink: 0;
        height: calc(100vh - 160px);
        max-height: calc(100vh - 160px);
    }

        .drawer-container.fullscreen {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            width: 100%;
            height: 100%;
            max-height: 100%;
            z-index: 1000;
            background: white;
        }

    .crowdstrike-tabs {
        background: transparent !important;
    }

        .crowdstrike-tabs .mud-tabs-toolbar {
            background: transparent !important;
            gap: 4px !important;
        }

    .crowdstrike-tab {
        padding: 8px 20px !important;
        font-weight: 500 !important;
        font-size: 0.9rem !important;
        color: #4a5568 !important;
        text-transform: none !important;
        border-radius: 8px !important;
        transition: all 0.2s ease !important;
    }

        .crowdstrike-tab:hover {
            background: rgba(0, 0, 0, 0.04) !important;
            color: #667eea !important;
        }

        .crowdstrike-tab.mud-tab-active {
            color: #667eea !important;
            font-weight: 600 !important;
            background: rgba(102, 126, 234, 0.08) !important;
        }

    .mud-tab-indicator {
        display: none !important;
    }
</style>

<MudPaper Class="pa-4" Style="min-height: calc(100vh - 80px); display: flex; flex-direction: column; overflow: hidden;">

    <div style="margin-bottom: 16px; flex-shrink: 0;">
        <MudText Typo="Typo.h6">☁️ Cloud Accounts Management</MudText>
        <MudText Typo="Typo.body2">Manage and monitor all your cloud accounts across providers</MudText>
    </div>

    <MudTabs Rounded="true"
             Elevation="0"
             Class="mb-4 crowdstrike-tabs"
             Style="flex-shrink: 0;"
             ActivePanelIndexChanged="OnTabChanged">

        <MudTabPanel Text="@AllTabText" Class="crowdstrike-tab" />
        <MudTabPanel Text="@AwsTabText" Class="crowdstrike-tab" />
        <MudTabPanel Text="@AzureTabText" Class="crowdstrike-tab" />
        <MudTabPanel Text="@GcpTabText" Class="crowdstrike-tab" />
    </MudTabs>

    <div class="main-layout">
        <div class="grid-container" style="@(drawerOpen && !drawerFullscreen ? "width: calc(100% - 516px); flex: none;" : "width: 100%; flex: none;")">
            <div style="flex: 1; min-height: 0;">
                <MudDataGrid T="CloudAccount"
                             @ref="_dataGrid"
                             Items="@FilteredAccounts"
                             Dense="true"
                             Hover="true"
                             Bordered="true"
                             Striped="true"
                             Filterable="true"
                             FilterMode="DataGridFilterMode.ColumnFilterRow"
                             FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive"
                             ShowColumnOptions="true"
                             FixedHeader="true"
                             @bind-PageSize="PageSize"
                             RowsPerPageOptions="@PageSizeOptions"
                             Height="100%"
                             Width="100%"
                             Loading="@isLoading"
                             ColumnResizeMode="ResizeMode.Column"
                             DragDropColumnReordering="true"
                             ColumnsPanelReordering="true"
                             ShowMenuIcon="true"
                             RowContextMenuClick="OpenContextMenu">

                    <Columns>
                        <PropertyColumn Property="x => x.Provider"
                                        Title="Provider"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.Provider" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.Provider</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.CloudAccountId"
                                        Title="Cloud Account ID"
                                        StickyLeft="true"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.CloudAccountId" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.CloudAccountId</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.CloudName"
                                        Title="Cloud Name"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.CloudName" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.CloudName</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.CloudOrgId"
                                        Title="Cloud Org ID"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.CloudOrgId" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.CloudOrgId</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.CloudRootAccountId"
                                        Title="Root Account ID"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.CloudRootAccountId" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.CloudRootAccountId</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.RegistrationType"
                                        Title="Registration Type"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.RegistrationType" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.RegistrationType</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.DeploymentMethod"
                                        Title="Deployment Method"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.DeploymentMethod" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.DeploymentMethod</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.Iomstatus"
                                        Title="IOM Status"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.Iomstatus" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.Iomstatus</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.RealTimeVisibilityAndDetectionStatus"
                                        Title="RTVD Status"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.RealTimeVisibilityAndDetectionStatus" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.RealTimeVisibilityAndDetectionStatus</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.OneClickSensorStatus"
                                        Title="1-Click Sensor Status"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.OneClickSensorStatus" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.OneClickSensorStatus</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.IdentityProtectionStatus"
                                        Title="Identity Protection Status"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.IdentityProtectionStatus" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.IdentityProtectionStatus</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.Dspmstatus"
                                        Title="DSPM Status"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.Dspmstatus" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.Dspmstatus</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.VulnerabilityScanningStatus"
                                        Title="Vulnerability Scanning Status"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.VulnerabilityScanningStatus" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.VulnerabilityScanningStatus</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.DateCreated"
                                        Title="Date Created"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.DateCreated.ToString("yyyy-MM-dd HH:mm")" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.DateCreated.ToString("yyyy-MM-dd HH:mm")</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <PropertyColumn Property="x => x.DateModified"
                                        Title="Date Modified"
                                        Resizable="true"
                                        Hideable="true">
                            <CellTemplate Context="cell">
                                <div class="cell-content">
                                    <MudTooltip Text="@cell.Item.DateModified.ToString("yyyy-MM-dd HH:mm")" Placement="Placement.Top">
                                        <span class="truncate-text">@cell.Item.DateModified.ToString("yyyy-MM-dd HH:mm")</span>
                                    </MudTooltip>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>

                        <TemplateColumn Title="Actions"
                                        StickyRight="true"
                                        Resizable="false"
                                        Hideable="false">
                            <CellTemplate Context="cell">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="@(() => OpenDrawer(cell.Item))" />
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>

                    <NoRecordsContent>
                        <MudText Class="pa-4">No matching records found</MudText>
                    </NoRecordsContent>

                    <PagerContent>
                        <MudDataGridPager T="CloudAccount" PageSizeOptions="@PageSizeOptions" />
                    </PagerContent>
                </MudDataGrid>
            </div>
        </div>

        @if (drawerOpen)
        {
            <div class="drawer-container @(drawerFullscreen ? "fullscreen" : "")">
                <MudPaper Class="pa-4" Style="height: 100%; display: flex; flex-direction: column; overflow: hidden;">

                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px; flex-shrink: 0;">
                        <MudText Typo="Typo.h6">Edit Cloud Account</MudText>
                        <div>
                            <MudIconButton Icon="@(drawerFullscreen ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                                           Size="Size.Medium"
                                           OnClick="ToggleFullscreen" />
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Size="Size.Medium"
                                           OnClick="CloseDrawer" />
                        </div>
                    </div>

                    <div style="flex: 1; overflow-y: auto;">
                        @if (editingAccount is not null)
                        {
                            <MudText Typo="Typo.subtitle1" Class="mb-3">Cloud Details</MudText>

                            <MudTextField T="string"
                                          Label="Cloud Name"
                                          Variant="Variant.Outlined"
                                          Class="mb-3"
                                          @bind-Value="editingAccount.CloudName" />

                            <MudTextField T="string"
                                          Label="Cloud Org ID"
                                          Variant="Variant.Outlined"
                                          Class="mb-3"
                                          @bind-Value="editingAccount.CloudOrgId" />

                            <MudTextField T="string"
                                          Label="IOM Status"
                                          Variant="Variant.Outlined"
                                          Class="mb-3"
                                          @bind-Value="editingAccount.Iomstatus" />

                            <MudTextField T="string"
                                          Label="RTVD Status"
                                          Variant="Variant.Outlined"
                                          Class="mb-3"
                                          @bind-Value="editingAccount.RealTimeVisibilityAndDetectionStatus" />

                            <MudDivider Class="my-4" />

                            <MudText Typo="Typo.subtitle1" Class="mb-3">Business Function</MudText>

                            <MudAutocomplete T="string"
                                             Label="Business Function Name"
                                             Variant="Variant.Outlined"
                                             Class="mb-3"
                                             Value="@editingAccount.BusinessFunctionName"
                                             ValueChanged="OnBusinessFunctionChanged"
                                             SearchFunc="SearchBusinessFunctions"
                                             Clearable="true"
                                             ResetValueOnEmptyText="true"
                                             CoerceText="true"
                                             Dense="true" />

                            <MudTextField T="string"
                                          Label="Owner"
                                          Value="@editingAccount.BusinessFunctionOwner"
                                          Disabled="true"
                                          Variant="Variant.Outlined"
                                          Class="mb-3" />

                            <MudTextField T="string"
                                          Label="LT Member"
                                          Value="@editingAccount.BusinessFunctionLtMember"
                                          Disabled="true"
                                          Variant="Variant.Outlined"
                                          Class="mb-3" />

                            <MudTextField T="string"
                                          Label="SPOC"
                                          Value="@editingAccount.BusinessFunctionSpoc"
                                          Disabled="true"
                                          Variant="Variant.Outlined"
                                          Class="mb-3" />

                            <MudDivider Class="my-4" />

                            <MudText Typo="Typo.subtitle1" Class="mb-3">Manual Details</MudText>

                            <MudSelect T="string"
                                       Label="Account Type"
                                       Variant="Variant.Outlined"
                                       Class="mb-3"
                                       @bind-Value="editingAccount.AccountType">

                                <MudSelectItem Value='"Hybrid"'>Hybrid</MudSelectItem>
                                <MudSelectItem Value='"Managed"'>Managed</MudSelectItem>
                                <MudSelectItem Value='"Self-Managed"'>Self-Managed</MudSelectItem>
                                <MudSelectItem Value='"Sandbox"'>Sandbox</MudSelectItem>
                                <MudSelectItem Value='"SingleAccount"'>SingleAccount</MudSelectItem>
                            </MudSelect>

                            <MudSelect T="string"
                                       Label="Overall Status"
                                       Variant="Variant.Outlined"
                                       Class="mb-3"
                                       @bind-Value="editingAccount.OverallStatus">

                                <MudSelectItem Value='"Active"'>Active</MudSelectItem>
                                <MudSelectItem Value='"Deleted"'>Deleted</MudSelectItem>
                                <MudSelectItem Value='"Disabled"'>Disabled</MudSelectItem>
                            </MudSelect>

                            <MudTextField T="string"
                                          Label="Cloud Tag Email"
                                          Variant="Variant.Outlined"
                                          Class="mb-3"
                                          @bind-Value="editingAccount.CloudTagEmail" />

                            <MudTextField T="string"
                                          Label="Remarks"
                                          Variant="Variant.Outlined"
                                          Lines="4"
                                          Class="mb-3"
                                          @bind-Value="editingAccount.Remarks" />

                            <MudStack Row="true"
                                      Spacing="2"
                                      Class="mt-6">

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           OnClick="SaveEdit">
                                    Save
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Secondary"
                                           OnClick="CloseDrawer">
                                    Cancel
                                </MudButton>
                            </MudStack>
                        }
                    </div>
                </MudPaper>
            </div>
        }
    </div>
</MudPaper>

<MudMenu PositionAtCursor="true" @ref="_contextMenu" id="_contextMenu">
    <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => EditFromContext())">
        Edit @_contextRow?.CloudName
    </MudMenuItem>
    <MudMenuItem Icon="@Icons.Material.Filled.History" OnClick="@ShowAudits">
        View Audits for @_contextRow?.CloudAccountId
    </MudMenuItem>
</MudMenu>

@code {
    private MudDataGrid<CloudAccount> _dataGrid = null!;
    private MudMenu _contextMenu = null!;
    private CloudAccount? _contextRow;
    private bool isLoading = true;
    private int PageSize = 10;
    private int[] PageSizeOptions = new[] { 10, 25, 50, 100 };
    private bool drawerFullscreen = false;

    private List<CloudAccount> cloudAccounts = new();
    private CloudAccountEditModel? editingAccount;
    private bool drawerOpen;
    private string selectedProvider = "All";

    private const string ApiBase = "api/CloudAccounts";
    private List<BusinessFunction> BusinessFunctions = new();

    private int AllCount => cloudAccounts?.Count ?? 0;
    private int AwsCount => cloudAccounts?.Count(x => x.Provider?.ToLower() == "aws") ?? 0;
    private int AzureCount => cloudAccounts?.Count(x => x.Provider?.ToLower() == "azure") ?? 0;
    private int GcpCount => cloudAccounts?.Count(x => x.Provider?.ToLower() == "gcp") ?? 0;

    private IEnumerable<CloudAccount> FilteredAccounts =>
        selectedProvider == "All"
            ? cloudAccounts
            : cloudAccounts.Where(x =>
                string.Equals(x.Provider, selectedProvider, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            var accountsTask = Http.GetFromJsonAsync<List<CloudAccount>>(ApiBase);
            var businessFunctionsTask = Http.GetFromJsonAsync<List<BusinessFunction>>("api/BusinessFunction");

            await Task.WhenAll(accountsTask!, businessFunctionsTask!);

            cloudAccounts = accountsTask?.Result ?? new();
            BusinessFunctions = businessFunctionsTask?.Result ?? new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void OnTabChanged(int index)
    {
        selectedProvider = index switch
        {
            1 => "AWS",
            2 => "Azure",
            3 => "GCP",
            _ => "All"
        };
        StateHasChanged();
    }

    private string AllTabText => $"All ({AllCount})";
    private string AwsTabText => $"AWS ({AwsCount})";
    private string AzureTabText => $"Azure ({AzureCount})";
    private string GcpTabText => $"GCP ({GcpCount})";

    private void ToggleFullscreen()
    {
        drawerFullscreen = !drawerFullscreen;
        StateHasChanged();
    }

    private async Task OpenContextMenu(DataGridRowClickEventArgs<CloudAccount> args)
    {
        _contextRow = args.Item;
        await _contextMenu.OpenMenuAsync(args.MouseEventArgs);
    }

    private void EditFromContext()
    {
        if (_contextRow is not null)
        {
            OpenDrawer(_contextRow);
        }
    }

    private async Task ShowAudits()
    {
        var auditResult = await cloudhistoryservice.GetAuditByAccId(_contextRow.CloudAccountId);
        var parameters = new DialogParameters
        {
            ["Title"] = $"Audit of Cloud Account ID: '{_contextRow.CloudAccountId}'",
            ["AuditRecords"] = auditResult  
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<HistoryDialog>("", parameters, options);
        var result = await dialog.Result;
    }

    private Task<IEnumerable<string>> SearchBusinessFunctions(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult(
                BusinessFunctions
                    .Where(x => !string.IsNullOrWhiteSpace(x.BusinessFunctionName))
                    .Select(x => x.BusinessFunctionName!)
                    .AsEnumerable());
        }

        var result = BusinessFunctions
            .Where(x =>
                !string.IsNullOrWhiteSpace(x.BusinessFunctionName) &&
                x.BusinessFunctionName.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(x => x.BusinessFunctionName!);

        return Task.FromResult(result);
    }

    private void OnBusinessFunctionChanged(string value)
    {
        if (editingAccount is null)
            return;

        editingAccount.BusinessFunctionName = value;

        var selected = BusinessFunctions
            .FirstOrDefault(x => x.BusinessFunctionName == value);

        if (selected is not null)
        {
            editingAccount.BusinessFunctionId = selected.Id;
            editingAccount.BusinessFunctionOwner = selected.BusinessFunctionOwner;
            editingAccount.BusinessFunctionLtMember = selected.BusinessFunctionLtMember;
            editingAccount.BusinessFunctionSpoc = selected.BusinessFunctionSpoc;
        }
        else
        {
            editingAccount.BusinessFunctionId = null;
            editingAccount.BusinessFunctionOwner = string.Empty;
            editingAccount.BusinessFunctionLtMember = string.Empty;
            editingAccount.BusinessFunctionSpoc = string.Empty;
        }

        StateHasChanged();
    }

    // private async Task OpenDrawer(CloudAccount account)
    // {
    //     drawerFullscreen = false;

    //     var selectedBusinessFunction = BusinessFunctions.FirstOrDefault(x =>
    //         x.Id == account.CloudAccountManualDetail?.BusinessFunctionId);

    //     editingAccount = new CloudAccountEditModel
    //     {
    //         Id = account.Id,
    //         CloudName = account.CloudName,
    //         CloudOrgId = account.CloudOrgId,
    //         Iomstatus = account.Iomstatus,
    //         RealTimeVisibilityAndDetectionStatus = account.RealTimeVisibilityAndDetectionStatus,

    //         BusinessFunctionId = account.CloudAccountManualDetail?.BusinessFunctionId,
    //         BusinessFunctionName = selectedBusinessFunction?.BusinessFunctionName,
    //         BusinessFunctionOwner = selectedBusinessFunction?.BusinessFunctionOwner,
    //         BusinessFunctionLtMember = selectedBusinessFunction?.BusinessFunctionLtMember,
    //         BusinessFunctionSpoc = selectedBusinessFunction?.BusinessFunctionSpoc,

    //         AccountType = account.CloudAccountManualDetail?.AccountType,
    //         OverallStatus = account.CloudAccountManualDetail?.OverallStatus,
    //         Remarks = account.CloudAccountManualDetail?.Remarks,
    //         CloudTagEmail = account.CloudAccountManualDetail?.CloudTagEmail
    //     };

    //     drawerOpen = true;
    // }
    private async Task OpenDrawer(CloudAccount account)
    {
        drawerFullscreen = false;

        var detail = account.CloudAccountManualDetails?.FirstOrDefault();

        var selectedBusinessFunction = BusinessFunctions.FirstOrDefault(x =>
            x.Id == detail?.BusinessFunctionId);

        editingAccount = new CloudAccountEditModel
        {
            Id = account.Id,
            CloudName = account.CloudName,
            CloudOrgId = account.CloudOrgId,
            Iomstatus = account.Iomstatus,
            RealTimeVisibilityAndDetectionStatus = account.RealTimeVisibilityAndDetectionStatus,

            BusinessFunctionId = detail?.BusinessFunctionId,
            BusinessFunctionName = selectedBusinessFunction?.BusinessFunctionName,
            BusinessFunctionOwner = selectedBusinessFunction?.BusinessFunctionOwner,
            BusinessFunctionLtMember = selectedBusinessFunction?.BusinessFunctionLtMember,
            BusinessFunctionSpoc = selectedBusinessFunction?.BusinessFunctionSpoc,

            AccountType = detail?.AccountType,
            OverallStatus = detail?.OverallStatus,
            Remarks = detail?.Remarks,
            CloudTagEmail = detail?.CloudTagEmail
        };

        drawerOpen = true;
    }

    private void CloseDrawer()
    {
        drawerOpen = false;
        drawerFullscreen = false;
        editingAccount = null;
    }

