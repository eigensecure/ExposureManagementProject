    private async Task SaveEdit()
    {
        if (editingAccount is null)
            return;

        var existing = cloudAccounts.FirstOrDefault(x => x.Id == editingAccount.Id);

        if (existing is null)
            return;

        existing.CloudName = editingAccount.CloudName;
        existing.CloudOrgId = editingAccount.CloudOrgId;
        existing.Iomstatus = editingAccount.Iomstatus;
        existing.RealTimeVisibilityAndDetectionStatus =
            editingAccount.RealTimeVisibilityAndDetectionStatus;

        existing.DateModified = DateTime.UtcNow;

        existing.CloudAccountManualDetails ??= new List<CloudAccountManualDetail>();

        var detail = existing.CloudAccountManualDetails.FirstOrDefault();

        if (detail == null)
        {
            detail = new CloudAccountManualDetail
            {
                CloudAccountId = existing.Id,
                DateCreated = DateTime.UtcNow,
                FirstUpdatedDate = DateTime.UtcNow
            };

            existing.CloudAccountManualDetails.Add(detail);
        }

        detail.BusinessFunctionId = editingAccount.BusinessFunctionId;
        detail.AccountType = editingAccount.AccountType;
        detail.OverallStatus = editingAccount.OverallStatus;
        detail.Remarks = editingAccount.Remarks;
        detail.CloudTagEmail = editingAccount.CloudTagEmail;
        detail.DateModified = DateTime.UtcNow;
        detail.LastUpdatedDate = DateTime.UtcNow;

        var response = await Http.PutAsJsonAsync($"{ApiBase}/{existing.Id}", existing);

        if (response.IsSuccessStatusCode)
        {
            cloudAccounts = await Http.GetFromJsonAsync<List<CloudAccount>>(ApiBase) ?? new();
            CloseDrawer();
            Snackbar.Add("Cloud account updated successfully", Severity.Success);
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            Snackbar.Add($"Save failed: {error}", Severity.Error);
        }
    }
